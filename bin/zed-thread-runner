    parser.add_argument(
        "--hide-project",
        action="append",
        default=[],
        metavar="PROJECT",
        help="Hide PROJECT from the default TUI list. Can be passed more than once.",
    )
    parser.add_argument(
        "--unhide-project",
        action="append",
        default=[],
        metavar="PROJECT",
        help="Unhide PROJECT. Can be passed more than once.",
    )
    parser.add_argument(
        "--list-hidden",
        action="store_true",
        help="List hidden projects and exit.",
    )
    parser.add_argument(
        "--hide-thread",
        action="append",
        default=[],
        metavar="KEY",
        help="Hide a thread key from the default TUI list. Supports local paths and ssh:host:/path keys.",
    )
    parser.add_argument(
        "--unhide-thread",
        action="append",
        default=[],
        metavar="KEY",
        help="Unhide a thread key. Supports local paths and ssh:host:/path keys.",
    )
    parser.add_argument(
        "--list-hidden-threads",
        action="store_true",
        help="List hidden thread keys and exit.",
    )
    parser.add_argument(
        "--pin-project",
        action="append",
        default=[],
        metavar="PROJECT",
        help="Pin PROJECT to the top of TUI lists. Can be passed more than once.",
    )
    parser.add_argument(
        "--unpin-project",
        action="append",
        default=[],
        metavar="PROJECT",
        help="Unpin PROJECT. Can be passed more than once.",
    )
    parser.add_argument(
