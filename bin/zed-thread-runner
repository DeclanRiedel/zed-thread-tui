def build_threads(projects: list[Path], default_command: str | None) -> list[ThreadCommand]:
    commands = load_commands()
    processes = load_processes()
    aliases = load_aliases()
    threads: list[ThreadCommand] = []
    for project in projects:
        command = effective_command_for_key(str(project), default_command, commands)
        thread = ThreadCommand(project=project, command=command, alias=aliases.get(str(project)))
        entries = process_entries_for_thread(processes, str(project))
        live_entries: list[dict[str, int | str]] = []
        for process_key, process_data in entries.items():
            pgid = process_data.get("pgid")
            pid = process_data.get("pid")
            if isinstance(pgid, int) and is_pgid_alive(pgid):
                live_entries.append(process_data)
            else:
                unregister_process_key(process_key)
        if live_entries:
            primary = live_entries[0]
            command = str(primary.get("command", command))
            thread.registered_pgid = primary.get("pgid") if isinstance(primary.get("pgid"), int) else None
            thread.registered_pid = primary.get("pid") if isinstance(primary.get("pid"), int) else None
            thread.command = command
            thread.running_slot = ",".join(sorted(str(entry.get("command_slot", "manual")) for entry in live_entries))
            thread.last_status = "running"
        threads.append(thread)
    return threads


def build_remote_threads(default_command: str | None) -> list[ThreadCommand]:
    commands = load_commands()
    processes = load_processes()
    aliases = load_aliases()
    hidden = hidden_thread_keys()
    threads: list[ThreadCommand] = []
    for spec in zed_remote_thread_specs():
        host = str(spec["host"])
        remote_path = str(spec["path"])
        key = remote_thread_key(host, remote_path)
        if key in hidden:
            continue
        command = effective_command_for_key(key, default_command, commands)
        thread = ThreadCommand(
            project=Path(remote_path),
            command=command,
            remote_host=host,
            remote_path=remote_path,
            remote_port=int(spec["port"]) if spec.get("port") else None,
            alias=aliases.get(key),
        )
        entries = process_entries_for_thread(processes, key)
        live_entries: list[dict[str, int | str]] = []
        for process_key, process_data in entries.items():
            pgid = process_data.get("pgid")
            pid = process_data.get("pid")
            if isinstance(pgid, int) and is_pgid_alive(pgid):
                live_entries.append(process_data)
            else:
                unregister_process_key(process_key)
        if live_entries:
            primary = live_entries[0]
            command = str(primary.get("command", command))
            thread.registered_pgid = primary.get("pgid") if isinstance(primary.get("pgid"), int) else None
            thread.registered_pid = primary.get("pid") if isinstance(primary.get("pid"), int) else None
            thread.command = command
            thread.running_slot = ",".join(sorted(str(entry.get("command_slot", "manual")) for entry in live_entries))
            thread.last_status = "running"
        threads.append(thread)
    return threads


def thread_for_project(project: Path, default_command: str | None) -> ThreadCommand:
    return build_threads([project.expanduser().resolve()], default_command)[0]


def thread_for_key(key: str, default_command: str | None) -> ThreadCommand | None:
    if key.startswith("ssh:"):
        for thread in build_remote_threads(default_command):
            if thread.key == key:
                return thread
        parts = remote_parts_from_key(key)
        if parts is None:
            return None
        host, remote_path = parts
        command = effective_command_for_key(key, default_command)
        return ThreadCommand(
            project=Path(remote_path),
            command=command,
            remote_host=host,
            remote_path=remote_path,
            alias=load_aliases().get(key),
        )
    project = Path(key).expanduser().resolve()
    if not project.exists() or not project.is_dir():
        return None
    return thread_for_project(project, default_command)


def run_project(project: Path, command: str | None, focus_zed: bool, stop_all_first: bool, focus_limit: int, command_slot: str = "manual") -> int:
    project = project.expanduser().resolve()
    if stop_all_first:
        stop_all_registered_processes()
    thread = thread_for_project(project, command)
    if focus_zed:
        message, _ = focus_project_in_zed(project, focus_limit=focus_limit)
        print(message)
    thread.start(command_slot=command_slot)
    process = thread.slot_processes.get(command_slot) if command_slot in ("1", "2") else thread.process
    if process is None:
        print(thread.last_status, file=sys.stderr)
        return 1
    commands = load_commands()
    commands[thread.key] = thread.command
    save_commands(commands)
    set_active_command_slot(thread.key, command_slot if command_slot in ("1", "2") else active_command_slot(thread.key, thread.command))
    record_command_history(thread.key, thread.command)
    print(f"running {project}: pid {process.pid}")
    return 0


def run_slot(slot: int, command: str | None, focus_zed: bool, stop_all_first: bool, focus_limit: int, command_slot: int | None = None) -> int:
    key = key_for_slot(slot)
    if key is None:
        print(f"no project assigned to slot {slot}", file=sys.stderr)
        return 1
    if command_slot is not None:
        command = command_for_slot(key, command_slot)
        if not command:
            print(f"cmd{command_slot} empty for slot {slot}", file=sys.stderr)
            return 1
        commands = load_commands()
        commands[key] = command
        save_commands(commands)
        set_active_command_slot(key, command_slot)
    if not key.startswith("ssh:"):
        return run_project(Path(key), command, focus_zed=focus_zed, stop_all_first=stop_all_first, focus_limit=focus_limit, command_slot=str(command_slot) if command_slot else "manual")
    if stop_all_first:
        stop_all_registered_processes()
    thread = thread_for_key(key, command)
    if thread is None:
        print(f"no remote thread assigned to slot {slot}", file=sys.stderr)
        return 1
    if focus_zed:
        ok, message = focus_remote_in_zed(str(thread.remote_host), str(thread.remote_path))
        print(message, file=sys.stdout if ok else sys.stderr)
    thread.start(command_slot=str(command_slot) if command_slot else "manual")
    process = thread.slot_processes.get(str(command_slot)) if command_slot else thread.process
    if process is None:
        print(thread.last_status, file=sys.stderr)
        return 1
    commands = load_commands()
    commands[thread.key] = thread.command
    save_commands(commands)
    active_slot = str(command_slot) if command_slot else active_command_slot(thread.key, thread.command)
    set_active_command_slot(thread.key, active_slot)
    record_command_history(thread.key, thread.command)
    print(f"running {thread.key}: pid {process.pid}")
    return 0


def focus_slot(slot: int, focus_limit: int) -> int:
    key = key_for_slot(slot)
    if key is None:
        print(f"no project assigned to slot {slot}", file=sys.stderr)
        return 1
    if not key.startswith("ssh:"):
        message, _ = focus_project_in_zed(Path(key), focus_limit=focus_limit)
        print(message)
        return 0
    thread = thread_for_key(key, None)
    if thread is None:
        print(f"no remote thread assigned to slot {slot}", file=sys.stderr)
        return 1
    ok, message = focus_remote_in_zed(str(thread.remote_host), str(thread.remote_path))
    print(message, file=sys.stdout if ok else sys.stderr)
    return 0 if ok else 1


def stop_slot(slot: int) -> int:
    key = key_for_slot(slot)
    if key is None:
        print(f"no project assigned to slot {slot}", file=sys.stderr)
        return 1
    data = load_processes().get(key)
    if not data:
        print(f"no tracked command for slot {slot}")
        return 0
    pgid = data.get("pgid")
    if isinstance(pgid, int):
        stop_process_group(pgid)
    unregister_process_key(key)
    print(f"stopped slot {slot}: {key}")
    return 0


def parse_leader_combo(combo: str) -> tuple[int, str] | None:
    combo = combo.strip()
    digits = ""
    index = 0
    while index < len(combo) and combo[index].isdigit():
        digits += combo[index]
        index += 1
    action = combo[index:]
    if not digits or not action:
        return None
    try:
        slot = int(digits)
    except ValueError:
        return None
    return slot, action


def run_leader_combo(combo: str, focus_zed: bool, focus_limit: int) -> int:
    parsed = parse_leader_combo(combo)
    if parsed is None:
        print("leader combo must be digits followed by an action, e.g. 9f or 9R1", file=sys.stderr)
        return 2
    slot, action = parsed
    key = key_for_slot(slot)
    if key is None:
        print(f"no project assigned to slot {slot}", file=sys.stderr)
        return 1
    if action in ("e1", "e2"):
        print(f"leader combo {combo} edits cmd{action[-1]}; open the TUI to edit commands", file=sys.stderr)
        return 2
    if action == "f":
        return focus_slot(slot, focus_limit)
    if action == "F":
        if key.startswith("ssh:"):
            print(f"slot {slot} is remote; Rider focus only supports local projects", file=sys.stderr)
            return 1
        process, message = focus_project_in_rider(Path(key))
        print(message)
        return 0 if process is not None else 1
    if action == "r":
        return run_slot(slot, None, focus_zed=focus_zed, stop_all_first=True, focus_limit=focus_limit)
    if action == "x":
        return stop_slot(slot)
    if action == "a":
        stop_all_registered_processes()
        print(f"stopped all from slot {slot}: {key}")
        return 0
    if action == "h":
        for hidden in hide_thread_keys([key]):
            print(hidden)
        return 0
    if action == "!":
        return run_slot(slot, None, focus_zed=focus_zed, stop_all_first=False, focus_limit=focus_limit, command_slot=1)
    if action == "@":
        return run_slot(slot, None, focus_zed=focus_zed, stop_all_first=False, focus_limit=focus_limit, command_slot=2)
    if action in ("s1", "s2"):
        return run_slot(slot, None, focus_zed=focus_zed, stop_all_first=False, focus_limit=focus_limit, command_slot=int(action[-1]))
    if action in ("R1", "R2"):
        return run_slot(slot, None, focus_zed=focus_zed, stop_all_first=True, focus_limit=focus_limit, command_slot=int(action[-1]))
    print(f"unsupported leader combo action: {action}", file=sys.stderr)
    return 2


def print_slots(sync_zed: bool) -> None:
    projects = default_projects(Path.cwd().resolve(), sync_zed=sync_zed)
    keys = [str(project) for project in projects]
    if sync_zed:
        keys.extend(thread.key for thread in build_remote_threads(None))
    slots = ensure_slot_keys(keys)
    for key, slot in sorted(slots.items(), key=lambda item: item[1]):
        print(f"{format_slot(slot)} {key}")


def zed_tasks(repo: Path, slot_count: int = DEFAULT_SLOT_COUNT) -> list[dict[str, object]]:
    runner_ref = str(repo)
    tasks: list[dict[str, object]] = [
        {
            "label": "thread runner: current worktree",
            "command": "nix",
            "args": ["run", runner_ref, "--", "--focus-zed-on-run", "$ZED_WORKTREE_ROOT"],
            "cwd": "$ZED_WORKTREE_ROOT",
            "use_new_terminal": False,
            "allow_concurrent_runs": True,
            "reveal": "always",
            "hide": "never",
        },
        {
            "label": "thread runner: all git worktrees",
            "command": "nix",
            "args": ["run", runner_ref, "--", "--focus-zed-on-run"],
            "cwd": "$ZED_WORKTREE_ROOT",
            "use_new_terminal": False,
            "allow_concurrent_runs": True,
            "reveal": "always",
            "hide": "never",
        },
        {
            "label": "thread runner: stop all then run current worktree",
            "command": "nix",
            "args": [
                "run",
                runner_ref,
                "--",
                "--stop-all-first",
                "--focus-zed-on-run",
                "--run-project",
                "$ZED_WORKTREE_ROOT",
            ],
            "cwd": "$ZED_WORKTREE_ROOT",
            "use_new_terminal": False,
            "allow_concurrent_runs": True,
            "reveal": "no_focus",
            "hide": "on_success",
        },
        {
            "label": "thread runner: register current worktree",
            "command": "nix",
            "args": ["run", runner_ref, "--", "--add-project", "$ZED_WORKTREE_ROOT"],
            "cwd": "$ZED_WORKTREE_ROOT",
            "use_new_terminal": False,
            "allow_concurrent_runs": True,
            "reveal": "no_focus",
            "hide": "on_success",
        },
        {
            "label": "thread runner: sync zed projects",
            "command": "nix",
            "args": ["run", runner_ref, "--", "--sync-zed-projects"],
            "cwd": "$ZED_WORKTREE_ROOT",
            "use_new_terminal": False,
            "allow_concurrent_runs": True,
            "reveal": "no_focus",
            "hide": "on_success",
        },
    ]
    for slot in range(1, slot_count + 1):
        tasks.extend(
            [
                {
                    "label": f"thread runner: focus {slot}",
                    "command": "nix",
                    "args": ["run", runner_ref, "--", "--focus-id", str(slot)],
                    "cwd": "$ZED_WORKTREE_ROOT",
                    "use_new_terminal": False,
                    "allow_concurrent_runs": True,
                    "reveal": "no_focus",
                    "hide": "on_success",
                },
                {
                    "label": f"thread runner: stop all then run {slot}",
                    "command": "nix",
                    "args": ["run", runner_ref, "--", "--stop-all-first", "--focus-zed-on-run", "--run-id", str(slot)],
                    "cwd": "$ZED_WORKTREE_ROOT",
                    "use_new_terminal": False,
                    "allow_concurrent_runs": True,
                    "reveal": "no_focus",
                    "hide": "on_success",
                },
                {
                    "label": f"thread runner: stop all then run {slot} cmd1",
                    "command": "nix",
                    "args": ["run", runner_ref, "--", "--stop-all-first", "--focus-zed-on-run", "--run-id", str(slot), "--cmd-slot", "1"],
                    "cwd": "$ZED_WORKTREE_ROOT",
                    "use_new_terminal": False,
                    "allow_concurrent_runs": True,
                    "reveal": "no_focus",
                    "hide": "on_success",
                },
                {
                    "label": f"thread runner: stop all then run {slot} cmd2",
                    "command": "nix",
                    "args": ["run", runner_ref, "--", "--stop-all-first", "--focus-zed-on-run", "--run-id", str(slot), "--cmd-slot", "2"],
                    "cwd": "$ZED_WORKTREE_ROOT",
                    "use_new_terminal": False,
                    "allow_concurrent_runs": True,
                    "reveal": "no_focus",
                    "hide": "on_success",
                },
                {
                    "label": f"thread runner: stop {slot}",
                    "command": "nix",
                    "args": ["run", runner_ref, "--", "--stop-id", str(slot)],
                    "cwd": "$ZED_WORKTREE_ROOT",
                    "use_new_terminal": False,
                    "allow_concurrent_runs": True,
                    "reveal": "no_focus",
                    "hide": "on_success",
                },
            ]
        )
    return tasks


def print_keymap_hints(slot_count: int, open_threads_menu: bool) -> None:
    print("keymap hints:")
    mode = "focus + threads menu" if open_threads_menu else "focus only"
    print(f"focus binding mode: {mode}")
    print('{ "context": "Workspace", "bindings": {')
    for slot in range(1, slot_count + 1):
        focus_binding = json.dumps(zed_focus_binding(f"thread runner: focus {slot}", open_threads_menu))
        print(f'  "space f {slot}": {focus_binding},')
        print(f'  "space r {slot}": ["task::Spawn", {{ "task_name": "thread runner: stop all then run {slot}" }}],')
        print(f'  "space r {slot} 1": ["task::Spawn", {{ "task_name": "thread runner: stop all then run {slot} cmd1" }}],')
        print(f'  "space r {slot} 2": ["task::Spawn", {{ "task_name": "thread runner: stop all then run {slot} cmd2" }}],')
        print(f'  "space x {slot}": ["task::Spawn", {{ "task_name": "thread runner: stop {slot}" }}],')
    print("} }")


def install_zed_config(slot_count: int) -> None:
    repo = Path.cwd().resolve()
    if not (repo / "flake.nix").exists():
        repo = Path(__file__).resolve().parents[1]
    target = Path.home() / ".config" / "zed" / "tasks.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(zed_tasks(repo, slot_count=slot_count), indent=2) + "\n")
    print(f"installed tasks: {target}")
    print_keymap_hints(slot_count, bool(load_config().get("open_threads_menu_on_focus", False)))


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    cwd = Path.cwd().resolve()

    if args.config_path:
        print(config_dir() / "config.json")
        return 0

    if args.focus_opens_threads_menu or args.focus_only:
        config = set_open_threads_menu_on_focus(args.focus_opens_threads_menu and not args.focus_only)
        mode = "focus + threads menu" if config.get("open_threads_menu_on_focus") else "focus only"
        print(f"focus binding mode: {mode}")
        return 0

    if args.compact or args.normal:
        config = load_config()
        config["compact"] = bool(args.compact and not args.normal)
        save_config(config)

    if args.install_zed_config:
        install_zed_config(args.slot_count)
        return 0

    if args.list_slots:
        print_slots(sync_zed=not args.no_zed_sync)
        return 0

    if args.reassign_slot:
        project_raw, slot_raw = args.reassign_slot
        slots = reassign_slot(Path(project_raw), int(slot_raw))
        for project, slot in sorted(slots.items(), key=lambda item: item[1]):
            print(f"{format_slot(slot)} {project}")
        return 0

    if args.focus_id is not None:
        return focus_slot(args.focus_id, focus_limit=args.focus_limit)

    if args.stop_id is not None:
        return stop_slot(args.stop_id)

    if args.leader_combo:
        return run_leader_combo(args.leader_combo, focus_zed=args.focus_zed_on_run, focus_limit=args.focus_limit)

    if args.run_id is not None:
        return run_slot(
            args.run_id,
            args.command,
            focus_zed=args.focus_zed_on_run,
            stop_all_first=args.stop_all_first or args.stop_all,
            focus_limit=args.focus_limit,
            command_slot=args.cmd_slot,
        )

    if args.add_project:
        projects = add_projects(Path(project) for project in args.add_project)
        for project in projects:
            print(project)
        return 0

    if args.remove_project:
        projects = remove_projects(Path(project) for project in args.remove_project)
        for project in projects:
            print(project)
        return 0

    if args.hide_project:
        for project in hide_projects(Path(project) for project in args.hide_project):
            print(project)
        return 0

    if args.unhide_project:
        for project in unhide_projects(Path(project) for project in args.unhide_project):
            print(project)
        return 0

    if args.list_hidden:
        for project in sorted(hidden_projects()):
            print(project)
        return 0

    if args.alias_thread:
        key, alias = args.alias_thread
        aliases = set_thread_alias(key, alias)
        normalized = normalize_thread_key(key)
        print(f"{normalized}: {aliases[normalized]}")
        return 0

    if args.unalias_thread:
        aliases = unset_thread_alias(args.unalias_thread)
        for key, alias in sorted(aliases.items()):
            print(f"{key}: {alias}")
        return 0

    if args.list_aliases:
        for key, alias in sorted(load_aliases().items()):
            print(f"{key}: {alias}")
        return 0

    if args.hide_thread:
        for key in hide_thread_keys(args.hide_thread):
            print(key)
        return 0

    if args.unhide_thread:
        for key in unhide_thread_keys(args.unhide_thread):
            print(key)
        return 0

    if args.list_hidden_threads:
        for key in sorted(hidden_thread_keys()):
            print(key)
        return 0

    if args.pin_project:
        for project in pin_projects(Path(project) for project in args.pin_project):
            print(project)
        return 0

    if args.unpin_project:
        for project in unpin_projects(Path(project) for project in args.unpin_project):
            print(project)
        return 0

    if args.list_pinned:
        for project in sorted(pinned_projects()):
            print(project)
        return 0

    if args.remote_focus_probe:
        host, remote_path = args.remote_focus_probe
        print(f"key: {remote_thread_key(host, remote_path)}")
        for candidate in remote_focus_candidates(host, remote_path):
            command = remote_focus_command(host, remote_path, candidate)
            print(f"candidate: {candidate}")
            print(f"command: {shlex.join(command)}")
        if args.try_remote_focus:
            ok, message = focus_remote_in_zed(host, remote_path, remote_ssh_uri(host, remote_path))
            print(message)
            return 0 if ok else 1
        return 0

    if args.set_remote_focus:
        host, remote_path, target = args.set_remote_focus
        targets = save_remote_focus_target(host, remote_path, target)
        key = remote_thread_key(host, remote_path)
        print(f"{key}: {targets[key]}")
        return 0

    if args.focus_remote:
        host, remote_path = args.focus_remote
        ok, message = focus_remote_in_zed(host, remote_path)
        print(message, file=sys.stdout if ok else sys.stderr)
        return 0 if ok else 1

    if args.list_remote_focus:
        for key, target in sorted(load_remote_focus_targets().items()):
            print(f"{key}: {target}")
        return 0

    if args.list_projects:
        for project in load_projects():
            print(project)
        return 0

    if args.set_cmd_slot:
        key_raw, slot_raw, command = args.set_cmd_slot
        if slot_raw not in ("1", "2"):
            print("command slot must be 1 or 2", file=sys.stderr)
            return 1
        key = normalize_thread_key(key_raw)
        state = save_thread_command_slot(key, int(slot_raw), command, active=True)
        commands = load_commands()
        commands[key] = command.strip()
        save_commands(commands)
        for name in ("cmd1", "cmd2", "active"):
            print(f"{name}: {state.get(name, '')}")
        return 0

    if args.list_cmd_slots:
        key = normalize_thread_key(args.list_cmd_slots)
        state = command_slot_state(key)
        for name in ("cmd1", "cmd2", "active"):
            print(f"{name}: {state.get(name, '')}")
        return 0

    if args.set_preset:
        project_raw, name, command = args.set_preset
        presets = set_preset(Path(project_raw), name, command)
        for preset_name, preset_command in sorted(presets.items()):
            print(f"{preset_name}: {preset_command}")
        return 0

    if args.list_presets:
        project = str(Path(args.list_presets).expanduser().resolve())
        for name, command in sorted(load_presets().get(project, {}).items()):
            print(f"{name}: {command}")
        return 0

    if args.list_zed_projects:
        for project in zed_thread_projects():
            print(project)
        return 0

    if args.list_zed_remotes:
        for spec in zed_remote_thread_specs():
            print(f"{spec['host']}:{spec['path']}")
        return 0

    if args.sync_zed_projects:
        projects = add_projects(zed_thread_projects())
        for project in projects:
            print(project)
        return 0

    if args.stop_all and not args.run_project:
        stopped = stop_all_registered_processes()
        print(f"stopped {stopped} tracked command(s)")
        return 0

    if args.run_project:
        project = Path(args.run_project).expanduser().resolve()
        return run_project(
            project,
            args.command,
            focus_zed=args.focus_zed_on_run,
            stop_all_first=args.stop_all_first or args.stop_all,
            focus_limit=args.focus_limit,
        )

    projects = unique_existing(Path(path) for path in args.projects)
    if args.register_args and projects:
        projects = add_projects(projects)
    if not projects:
        projects = default_projects(cwd, sync_zed=not args.no_zed_sync)
    ensure_slots(projects)
    threads = build_threads(projects, args.command)
    if not args.no_zed_sync:
        threads.extend(build_remote_threads(args.command))
        ensure_slot_keys(thread.key for thread in threads)
    if args.warm:
        for thread in threads:
            thread.warm()

    ui = RunnerUi(
        threads,
        focus_zed_on_run=args.focus_zed_on_run,
        focus_limit=args.focus_limit,
        sort_mode=args.sort_mode,
        cwd=cwd,
        default_command=args.command,
    )
    try:
        curses.wrapper(ui.run)
    except KeyboardInterrupt:
        for thread in threads:
            thread.stop()
        ui.stop_all_rider_processes()
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
