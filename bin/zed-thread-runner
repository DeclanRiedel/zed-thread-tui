#!/usr/bin/env python3
"""Thin terminal UI for running per-worktree commands through nix shells."""

from __future__ import annotations

import argparse
import curses
import json
import os
import shlex
import signal
import sqlite3
import subprocess
import sys
import time
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from typing import Iterable
from urllib.parse import quote


APP_NAME = "zed-thread-runner"
ZED_STATE_DIR = Path.home() / ".local" / "share" / "zed"
MAX_FOCUSED_WORKTREES = 4
ZED_STATE_REFRESH_SECONDS = 2.0
AI_RUNNING_WINDOW_SECONDS = 45
SORT_MODES = ["source", "name", "running", "failed", "focused", "ai"]
DEFAULT_SLOT_COUNT = 9
COMMAND_HISTORY_LIMIT = 25
LOG_TAIL_READ_BYTES = 64 * 1024
MAX_LOG_BYTES = 5 * 1024 * 1024
COMPACTED_LOG_BYTES = 512 * 1024
COLOR_DEFAULT = 1
COLOR_RUNNING = 2
COLOR_FAILED = 3
COLOR_WARMING = 4
COLOR_PINNED = 5
COLOR_REMOTE = 6
COLOR_AI_DONE = 7
COLOR_FOCUSED = 8


def state_dir() -> Path:
    base = os.environ.get("XDG_STATE_HOME")
    if base:
        return Path(base) / APP_NAME
    return Path.home() / ".local" / "state" / APP_NAME


def config_dir() -> Path:
    base = os.environ.get("XDG_CONFIG_HOME")
    if base:
        return Path(base) / APP_NAME
    return Path.home() / ".config" / APP_NAME


def default_config() -> dict[str, object]:
    return {
        "focus_limit": MAX_FOCUSED_WORKTREES,
        "leader_key": "space",
        "sort_mode": "source",
        "compact": False,
        "trust_zed_focus": False,
        "open_threads_menu_on_focus": False,
        "focus_zed_on_run": False,
        "show_cmd2_in_rows": False,
        "multi_command_mode": False,
        "hidden_projects": [],
        "hidden_threads": [],
        "pinned_projects": [],
        "remote_focus": {},
        "ssh_connections": [],
        "thread_ssh_dependencies": {},
    }


def load_config() -> dict[str, object]:
    config = default_config()
    path = config_dir() / "config.json"
    if not path.exists():
        return config
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return config
    if isinstance(data, dict):
        config.update(data)
    return config


def save_config(config: dict[str, object]) -> None:
    target = config_dir() / "config.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(config, indent=2, sort_keys=True) + "\n")


def tail_file_lines(path: Path, line_count: int, read_bytes: int = LOG_TAIL_READ_BYTES) -> list[str]:
    if line_count <= 0:
        return []
    try:
        size = path.stat().st_size
        with path.open("rb") as log:
            log.seek(max(0, size - read_bytes))
            data = log.read()
    except OSError:
        return ["<no log yet>"]
    lines = data.decode(errors="replace").splitlines()
    if size > read_bytes and lines:
        lines = lines[1:]
    return lines[-line_count:] if lines else ["<empty log>"]


def compact_log_file(path: Path, max_bytes: int = MAX_LOG_BYTES, keep_bytes: int = COMPACTED_LOG_BYTES) -> bool:
    try:
        size = path.stat().st_size
    except OSError:
        return False
    if size <= max_bytes:
        return False
    try:
        with path.open("rb") as source:
            source.seek(max(0, size - keep_bytes))
            data = source.read()
        marker = f"\n[{time.strftime('%Y-%m-%d %H:%M:%S')}] log compacted from {size} bytes\n".encode()
        path.write_bytes(marker + data)
    except OSError:
        return False
    return True


def clear_log_file(path: Path) -> bool:
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(f"[{time.strftime('%Y-%m-%d %H:%M:%S')}] log cleared\n")
    except OSError:
        return False
    return True


def remote_path_key(path: str) -> str:
    text = path.strip()
    if not text:
        return "/"
    if text.startswith("~/"):
        return text
    if text == "~":
        return "~"
    if not text.startswith("/"):
        return f"/{text}"
    return text


def remote_thread_key(host: str, path: str) -> str:
    return f"ssh:{host.strip()}:{remote_path_key(path)}"


def remote_host_label(user: str | None, host: str, port: int | None = None) -> str:
    label = f"{user}@{host}" if user else host
    return f"{label}:{port}" if port else label


def remote_uri_path(path: str) -> str:
    normalized = remote_path_key(path)
    if normalized == "~":
        normalized = "/~"
    elif normalized.startswith("~/"):
        normalized = f"/~/{normalized[2:]}"
    return quote(normalized, safe="/~._-")


def remote_ssh_uri(host: str, path: str) -> str:
    return f"ssh://{host.strip()}{remote_uri_path(path)}"


def remote_zed_uri(host: str, path: str) -> str:
    return f"zed://ssh/{host.strip()}{remote_uri_path(path)}"


def remote_focus_candidates(host: str, path: str) -> list[str]:
    return [remote_ssh_uri(host, path), remote_zed_uri(host, path)]


def load_remote_focus_targets() -> dict[str, str]:
    raw = load_config().get("remote_focus", {})
    if not isinstance(raw, dict):
        return {}
    return {str(key): str(value) for key, value in raw.items()}


def save_remote_focus_target(host: str, path: str, target: str) -> dict[str, str]:
    config = load_config()
    targets = load_remote_focus_targets()
    targets[remote_thread_key(host, path)] = target
    config["remote_focus"] = targets
    save_config(config)
    return targets


def load_remote_nix_cache() -> dict[str, str]:
    path = state_dir() / "remote-nix.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    return {str(key): str(value) for key, value in data.items() if str(value) in ("flake", "shell", "none")}


def save_remote_nix_cache(cache: dict[str, str]) -> None:
    target = state_dir() / "remote-nix.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(cache, indent=2, sort_keys=True) + "\n")


def cached_remote_nix_kind(host: str, path: str) -> str | None:
    return load_remote_nix_cache().get(remote_thread_key(host, path))


def save_remote_nix_kind(host: str, path: str, kind: str) -> str:
    if kind not in ("flake", "shell", "none"):
        kind = "none"
    cache = load_remote_nix_cache()
    cache[remote_thread_key(host, path)] = kind
    save_remote_nix_cache(cache)
    return kind


def remote_focus_template_values(host: str, path: str) -> dict[str, str]:
    normalized_path = remote_path_key(path)
    return {
        "host": host.strip(),
        "path": normalized_path,
        "uri": remote_ssh_uri(host, normalized_path),
        "zed_uri": remote_zed_uri(host, normalized_path),
        "key": remote_thread_key(host, normalized_path),
        "label": f"{host.strip()}:{normalized_path}",
    }


def remote_shell_command(path: str, command: str, nix_kind: str = "auto") -> str:
    quoted_path = shlex.quote(remote_path_key(path))
    quoted_command = shlex.quote(command)
    if nix_kind == "flake":
        return f"cd {quoted_path} && nix develop --command bash -lc {quoted_command}"
    if nix_kind == "shell":
        return f"cd {quoted_path} && nix-shell --run {quoted_command}"
    if nix_kind == "none":
        return f"cd {quoted_path} && bash -lc {quoted_command}"
    return (
        f"cd {quoted_path} && "
        "if [ -f flake.nix ]; then "
        f"nix develop --command bash -lc {quoted_command}; "
        "elif [ -f shell.nix ] || [ -f default.nix ]; then "
        f"nix-shell --run {quoted_command}; "
        "else "
        f"bash -lc {quoted_command}; "
        "fi"
    )


def remote_detect_nix_command(path: str) -> str:
    quoted_path = shlex.quote(remote_path_key(path))
    return (
        f"cd {quoted_path} && "
        "if [ -f flake.nix ]; then echo flake; "
        "elif [ -f shell.nix ] || [ -f default.nix ]; then echo shell; "
        "else echo none; "
        "fi"
    )


def remote_warm_shell_command(path: str, nix_kind: str) -> str:
    quoted_path = shlex.quote(remote_path_key(path))
    if nix_kind == "flake":
        return f"cd {quoted_path} && nix develop --command true"
    if nix_kind == "shell":
        return f"cd {quoted_path} && nix-shell --run true"
    return f"cd {quoted_path} && true"


def remote_ssh_command(host: str, remote_command: str, port: int | None = None) -> list[str]:
    ssh_command = ["ssh"]
    ssh_host = host
    if port:
        ssh_command.extend(["-p", str(port)])
        suffix = f":{port}"
        if ssh_host.endswith(suffix):
            ssh_host = ssh_host[: -len(suffix)]
    ssh_command.extend([ssh_host, remote_command])
    return ssh_command


def remote_command_for_project(
    host: str,
    path: str,
    command: str,
    port: int | None = None,
    nix_kind: str = "auto",
) -> list[str]:
    return remote_ssh_command(host, remote_shell_command(path, command, nix_kind), port)


def remote_warm_command_for_project(host: str, path: str, port: int | None, nix_kind: str) -> list[str] | None:
    if nix_kind == "none":
        return None
    return remote_ssh_command(host, remote_warm_shell_command(path, nix_kind), port)


def detect_remote_nix_kind(host: str, path: str, port: int | None = None, timeout: float = 8.0) -> str:
    key = remote_thread_key(host, path)
    cached = load_remote_nix_cache().get(key)
    if cached:
        return cached
    try:
        result = subprocess.run(
            remote_ssh_command(host, remote_detect_nix_command(path), port),
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=timeout,
        )
    except (OSError, subprocess.CalledProcessError, subprocess.TimeoutExpired):
        return save_remote_nix_kind(host, path, "none")
    kind = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else "none"
    return save_remote_nix_kind(host, path, kind)


def remote_focus_command(host: str, path: str, target: str | None = None) -> list[str]:
    if target is None:
        target = load_remote_focus_targets().get(remote_thread_key(host, path), remote_ssh_uri(host, path))
    rendered = target.format(**remote_focus_template_values(host, path))
    if rendered.startswith("cmd:"):
        return shlex.split(rendered.removeprefix("cmd:").strip())
    if rendered.startswith("zed://"):
        return ["zed", rendered]
    return ["zed", "-r", rendered]


def focus_remote_in_zed(host: str, path: str, target: str | None = None) -> tuple[bool, str]:
    command = remote_focus_command(host, path, target)
    try:
        subprocess.run(command, check=True, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE, text=True)
    except FileNotFoundError:
        return False, "zed CLI not found"
    except subprocess.CalledProcessError as error:
        detail = error.stderr.strip()
        suffix = f": {detail}" if detail else ""
        return False, f"remote focus failed{suffix}"
    return True, f"focused remote: {host.strip()}:{remote_path_key(path)}"


def hidden_projects() -> set[Path]:
    raw = load_config().get("hidden_projects", [])
    if not isinstance(raw, list):
        return set()
    return {Path(str(project)).expanduser().resolve() for project in raw}


def hidden_thread_keys() -> set[str]:
    raw = load_config().get("hidden_threads", [])
    if not isinstance(raw, list):
        return set()
    return {str(key) for key in raw}


def hidden_thread_entries() -> list[str]:
    return sorted(hidden_thread_keys())


def hide_thread_keys(keys: Iterable[str]) -> list[str]:
    config = load_config()
    hidden = hidden_thread_keys()
    hidden.update(str(key) for key in keys)
    config["hidden_threads"] = sorted(hidden)
    save_config(config)
    return sorted(hidden)


def unhide_thread_keys(keys: Iterable[str]) -> list[str]:
    config = load_config()
    hidden = hidden_thread_keys()
    hidden.difference_update(str(key) for key in keys)
    config["hidden_threads"] = sorted(hidden)
    save_config(config)
    return sorted(hidden)


def hide_projects(projects: Iterable[Path]) -> list[Path]:
    config = load_config()
    hidden = hidden_projects()
    resolved_projects = [project.expanduser().resolve() for project in projects]
    hidden.update(resolved_projects)
    config["hidden_projects"] = sorted(str(project) for project in hidden)
    hidden_threads = hidden_thread_keys()
    hidden_threads.update(str(project) for project in resolved_projects)
    config["hidden_threads"] = sorted(hidden_threads)
    save_config(config)
    return sorted(hidden)


def unhide_projects(projects: Iterable[Path]) -> list[Path]:
    config = load_config()
    hidden = hidden_projects()
    resolved_projects = [project.expanduser().resolve() for project in projects]
    hidden.difference_update(resolved_projects)
    config["hidden_projects"] = sorted(str(project) for project in hidden)
    hidden_threads = hidden_thread_keys()
    hidden_threads.difference_update(str(project) for project in resolved_projects)
    config["hidden_threads"] = sorted(hidden_threads)
    save_config(config)
    return sorted(hidden)


def pinned_projects() -> set[Path]:
    raw = load_config().get("pinned_projects", [])
    if not isinstance(raw, list):
        return set()
    return {Path(str(project)).expanduser().resolve() for project in raw}


def pin_projects(projects: Iterable[Path]) -> list[Path]:
    config = load_config()
    pinned = pinned_projects()
    pinned.update(project.expanduser().resolve() for project in projects)
    config["pinned_projects"] = sorted(str(project) for project in pinned)
    save_config(config)
    return sorted(pinned)


def unpin_projects(projects: Iterable[Path]) -> list[Path]:
    config = load_config()
    pinned = pinned_projects()
    pinned.difference_update(project.expanduser().resolve() for project in projects)
    config["pinned_projects"] = sorted(str(project) for project in pinned)
    save_config(config)
    return sorted(pinned)


def load_commands() -> dict[str, str]:
    path = state_dir() / "commands.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    return {str(k): str(v) for k, v in data.items()}


def load_command_history() -> dict[str, list[str]]:
    path = state_dir() / "command-history.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    history: dict[str, list[str]] = {}
    for key, values in data.items():
        if not isinstance(values, list):
            continue
        commands = []
        for value in values:
            command = str(value).strip()
            if command and command not in commands:
                commands.append(command)
        history[str(key)] = commands[:COMMAND_HISTORY_LIMIT]
    return history


def load_command_slots() -> dict[str, dict[str, str]]:
    path = state_dir() / "command-slots.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    slots: dict[str, dict[str, str]] = {}
    for key, values in data.items():
        if not isinstance(values, dict):
            continue
        cmd1 = str(values.get("cmd1", "")).strip()
        cmd2 = str(values.get("cmd2", "")).strip()
        active = str(values.get("active", "manual"))
        if active not in ("1", "2", "manual"):
            active = "manual"
        slots[str(key)] = {"cmd1": cmd1, "cmd2": cmd2, "active": active}
    return slots


def load_aliases() -> dict[str, str]:
    path = state_dir() / "aliases.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    return {str(key): str(value) for key, value in data.items() if str(value).strip()}


def load_processes() -> dict[str, dict[str, int | str]]:
    path = state_dir() / "processes.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    return {str(k): v for k, v in data.items() if isinstance(v, dict)}


def load_projects() -> list[Path]:
    path = state_dir() / "projects.json"
    if not path.exists():
        return []
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return []
    if not isinstance(data, list):
        return []
    return unique_existing(Path(str(project)) for project in data)


def load_focus_history() -> list[Path]:
    path = state_dir() / "focus-history.json"
    if not path.exists():
        return []
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return []
    if not isinstance(data, list):
        return []
    return unique_existing(Path(str(project)) for project in data)


def load_slots() -> dict[str, int]:
    path = state_dir() / "slots.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    slots: dict[str, int] = {}
    for project, slot in data.items():
        try:
            slot_int = int(slot)
        except (TypeError, ValueError):
            continue
        if slot_int <= 0:
            continue
        if str(project).startswith("ssh:"):
            slots[str(project)] = slot_int
        else:
            slots[str(Path(str(project)).expanduser().resolve())] = slot_int
    return slots


def load_ai_seen() -> dict[str, str]:
    path = state_dir() / "ai-seen.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    return {str(project): str(updated_at) for project, updated_at in data.items()}


def save_commands(commands: dict[str, str]) -> None:
    target = state_dir() / "commands.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(commands, indent=2, sort_keys=True) + "\n")


def save_command_history(history: dict[str, list[str]]) -> None:
    target = state_dir() / "command-history.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(history, indent=2, sort_keys=True) + "\n")


def save_command_slots(slots: dict[str, dict[str, str]]) -> None:
    target = state_dir() / "command-slots.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(slots, indent=2, sort_keys=True) + "\n")


def record_command_history(key: str, command: str, limit: int = COMMAND_HISTORY_LIMIT) -> list[str]:
    command = command.strip()
    if not command:
        return load_command_history().get(key, [])
    history = load_command_history()
    entries = [command, *[entry for entry in history.get(key, []) if entry != command]]
    history[key] = entries[:limit]
    save_command_history(history)
    return history[key]


def default_command_slot_state() -> dict[str, str]:
    return {"cmd1": "", "cmd2": "", "active": "manual"}


def command_slot_state(key: str, slots: dict[str, dict[str, str]] | None = None) -> dict[str, str]:
    data = (slots if slots is not None else load_command_slots()).get(key, {})
    state = default_command_slot_state()
    state.update({name: str(data.get(name, "")).strip() for name in ("cmd1", "cmd2")})
    active = str(data.get("active", "manual"))
    state["active"] = active if active in ("1", "2", "manual") else "manual"
    return state


def save_thread_command_slot(key: str, slot: int, command: str, active: bool = False) -> dict[str, str]:
    if slot not in (1, 2):
        raise ValueError("command slot must be 1 or 2")
    slots = load_command_slots()
    state = command_slot_state(key, slots)
    state[f"cmd{slot}"] = command.strip()
    if active:
        state["active"] = str(slot)
    slots[key] = state
    save_command_slots(slots)
    return state


def set_active_command_slot(key: str, slot: int | str) -> dict[str, str]:
    if slot not in (1, 2, "1", "2", "manual"):
        raise ValueError("active command slot must be 1, 2, or manual")
    slots = load_command_slots()
    state = command_slot_state(key, slots)
    state["active"] = str(slot)
    slots[key] = state
    save_command_slots(slots)
    return state


def command_for_slot(key: str, slot: int, slots: dict[str, dict[str, str]] | None = None) -> str:
    if slot not in (1, 2):
        raise ValueError("command slot must be 1 or 2")
    state = command_slot_state(key, slots)
    return state.get(f"cmd{slot}", "").strip()


def active_command_slot(key: str, command: str, slots: dict[str, dict[str, str]] | None = None) -> str:
    state = command_slot_state(key, slots)
    command = command.strip()
    if command and command == state.get("cmd1", ""):
        return "1"
    if command and command == state.get("cmd2", ""):
        return "2"
    if command:
        return "manual"
    active = state.get("active", "manual")
    if active in ("1", "2") and state.get(f"cmd{active}", ""):
        return active
    return "manual"


def effective_command_for_key(key: str, default_command: str | None, commands: dict[str, str] | None = None) -> str:
    state = command_slot_state(key)
    if state.get("cmd1", ""):
        return state["cmd1"]
    command = (commands if commands is not None else load_commands()).get(key, "").strip()
    if command:
        return command
    active = state.get("active", "manual")
    if active in ("1", "2") and state.get(f"cmd{active}", ""):
        return state[f"cmd{active}"]
    return default_command or ""


def save_aliases(aliases: dict[str, str]) -> None:
    target = state_dir() / "aliases.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(aliases, indent=2, sort_keys=True) + "\n")


def normalize_thread_key(raw: str) -> str:
    text = raw.strip()
    if text.startswith("ssh:"):
        return text
    return str(Path(text).expanduser().resolve())


def set_thread_alias(key: str, alias: str) -> dict[str, str]:
    aliases = load_aliases()
    normalized = normalize_thread_key(key)
    alias = alias.strip()
    if alias:
        aliases[normalized] = alias
    else:
        aliases.pop(normalized, None)
    save_aliases(aliases)
    return aliases


def unset_thread_alias(key: str) -> dict[str, str]:
    aliases = load_aliases()
    aliases.pop(normalize_thread_key(key), None)
    save_aliases(aliases)
    return aliases


def common_prefix(values: list[str]) -> str:
    if not values:
        return ""
    prefix = values[0]
    for value in values[1:]:
        while not value.startswith(prefix) and prefix:
            prefix = prefix[:-1]
    return prefix


def complete_command_value(value: str, candidates: list[str]) -> str:
    matches = [candidate for candidate in candidates if candidate.startswith(value) and candidate != value]
    if not matches:
        return value
    prefix = common_prefix(matches)
    return prefix if len(prefix) > len(value) else matches[0]


def save_ai_seen(seen: dict[str, str]) -> None:
    target = state_dir() / "ai-seen.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(seen, indent=2, sort_keys=True) + "\n")


def save_slots(slots: dict[str, int]) -> None:
    target = state_dir() / "slots.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(slots, indent=2, sort_keys=True) + "\n")


def ensure_slots(projects: Iterable[Path]) -> dict[str, int]:
    return ensure_slot_keys(str(project.expanduser().resolve()) for project in projects)


def ensure_slot_keys(keys: Iterable[str]) -> dict[str, int]:
    slots = load_slots()
    used = set(slots.values())
    changed = False
    for key in keys:
        if key in slots:
            continue
        slot = 1
        while slot in used:
            slot += 1
        slots[key] = slot
        used.add(slot)
        changed = True
    if changed:
        save_slots(slots)
    return slots


def project_for_slot(slot: int) -> Path | None:
    for project, project_slot in load_slots().items():
        if project_slot == slot:
            if project.startswith("ssh:"):
                return None
            path = Path(project)
            if path.exists() and path.is_dir():
                return path
    return None


def key_for_slot(slot: int) -> str | None:
    for key, project_slot in load_slots().items():
        if project_slot == slot:
            return key
    return None


def remote_parts_from_key(key: str) -> tuple[str, str] | None:
    if not key.startswith("ssh:"):
        return None
    rest = key.removeprefix("ssh:")
    path_start = rest.find(":/")
    if path_start == -1:
        path_start = rest.find(":~")
    if path_start == -1:
        return None
    return rest[:path_start], rest[path_start + 1 :]


def reassign_slot(project: Path, slot: int) -> dict[str, int]:
    if slot <= 0:
        raise ValueError("slot must be positive")
    resolved = str(project.expanduser().resolve())
    slots = {path: value for path, value in load_slots().items() if value != slot and path != resolved}
    slots[resolved] = slot
    save_slots(slots)
    return slots


def format_slot(slot: int | None) -> str:
    if slot is None:
        return "--"
    return f"{slot:02d}" if slot < 100 else str(slot)


def load_presets() -> dict[str, dict[str, str]]:
    path = state_dir() / "presets.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    presets: dict[str, dict[str, str]] = {}
    for project, values in data.items():
        if isinstance(values, dict):
            presets[str(project)] = {str(name): str(command) for name, command in values.items()}
    return presets


def save_presets(presets: dict[str, dict[str, str]]) -> None:
    target = state_dir() / "presets.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(presets, indent=2, sort_keys=True) + "\n")


def set_preset(project: Path, name: str, command: str) -> dict[str, str]:
    presets = load_presets()
    project_presets = presets.setdefault(str(project.expanduser().resolve()), {})
    project_presets[name] = command
    save_presets(presets)
    return project_presets


def save_projects(projects: list[Path]) -> None:
    target = state_dir() / "projects.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps([str(project) for project in projects], indent=2) + "\n")


def save_focus_history(projects: list[Path]) -> None:
    target = state_dir() / "focus-history.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps([str(project) for project in projects], indent=2) + "\n")


def add_projects(projects: Iterable[Path]) -> list[Path]:
    current = load_projects()
    merged = unique_existing([*current, *projects])
    ensure_slots(merged)
    save_projects(merged)
    return merged


def remove_projects(projects: Iterable[Path]) -> list[Path]:
    removed = {project.expanduser().resolve() for project in projects}
    kept = [project for project in load_projects() if project not in removed]
    save_projects(kept)
    return kept


def record_focused_project(project: Path, limit: int = MAX_FOCUSED_WORKTREES) -> list[Path]:
    resolved = project.expanduser().resolve()
    history = [resolved, *[entry for entry in load_focus_history() if entry != resolved]]
    kept = history[:limit]
    popped = history[limit:]
    save_focus_history(kept)
    return popped


def save_processes(processes: dict[str, dict[str, int | str]]) -> None:
    target = state_dir() / "processes.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(processes, indent=2, sort_keys=True) + "\n")


def register_process(project: Path, process: subprocess.Popen[bytes], command: str, command_slot: str = "manual") -> None:
    register_process_key(str(project), process, command, command_slot)


def command_process_key(key: str, command_slot: str = "manual") -> str:
    return f"{key}::cmd{command_slot}" if command_slot in ("1", "2") else key


def process_thread_key(key: str, data: dict[str, int | str] | None = None) -> str:
    if data and data.get("thread_key"):
        return str(data["thread_key"])
    if "::cmd" in key:
        return key.rsplit("::cmd", 1)[0]
    return key


def process_entries_for_thread(processes: dict[str, dict[str, int | str]], key: str) -> dict[str, dict[str, int | str]]:
    return {process_key: data for process_key, data in processes.items() if process_thread_key(process_key, data) == key}


def register_process_key(key: str, process: subprocess.Popen[bytes], command: str, command_slot: str = "manual") -> None:
    processes = load_processes()
    try:
        pgid = os.getpgid(process.pid)
    except ProcessLookupError:
        return
    processes[command_process_key(key, command_slot)] = {
        "pid": process.pid,
        "pgid": pgid,
        "command": command,
        "command_slot": command_slot,
        "thread_key": key,
    }
    save_processes(processes)


def ssh_process_key(name: str) -> str:
    return f"ssh-connection:{name}"


def is_pgid_alive(pgid: int) -> bool:
    try:
        os.killpg(pgid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def unregister_process(project: Path) -> None:
    unregister_process_key(str(project))


def unregister_process_key(key: str, command_slot: str | None = None) -> None:
    processes = load_processes()
    changed = False
    if command_slot is not None:
        changed = processes.pop(command_process_key(key, command_slot), None) is not None
    else:
        for process_key, data in list(processes.items()):
            if process_key == key or process_thread_key(process_key, data) == key:
                processes.pop(process_key, None)
                changed = True
    if changed:
        save_processes(processes)


def stop_process_group(pgid: int) -> None:
    try:
        os.killpg(pgid, signal.SIGTERM)
    except ProcessLookupError:
        return
    deadline = time.monotonic() + 1.5
    while time.monotonic() < deadline:
        try:
            os.killpg(pgid, 0)
        except ProcessLookupError:
            return
        time.sleep(0.05)
    try:
        os.killpg(pgid, signal.SIGKILL)
    except ProcessLookupError:
        pass


def stop_all_registered_processes() -> int:
    processes = load_processes()
    stopped = 0
    kept: dict[str, dict[str, int | str]] = {}
    for key, data in processes.items():
        if key.startswith("ssh-connection:"):
            kept[key] = data
            continue
        pgid = data.get("pgid")
        if isinstance(pgid, int):
            stop_process_group(pgid)
            stopped += 1
    save_processes(kept)
    return stopped


def discover_worktrees(cwd: Path) -> list[Path]:
    try:
        result = subprocess.run(
            ["git", "worktree", "list", "--porcelain"],
            cwd=cwd,
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except (OSError, subprocess.CalledProcessError):
        return [cwd]

    paths: list[Path] = []
    for line in result.stdout.splitlines():
        if line.startswith("worktree "):
            paths.append(Path(line.removeprefix("worktree ")).expanduser().resolve())
    return paths or [cwd]


def split_zed_paths(value: str | None) -> list[Path]:
    if not value:
        return []
    value = value.strip()
    if not value:
        return []
    try:
        parsed = json.loads(value)
    except json.JSONDecodeError:
        parsed = None
    if isinstance(parsed, list):
        return [Path(str(path)) for path in parsed if str(path)]
    if "\n" in value:
        return [Path(part) for part in value.splitlines() if part]
    if "\0" in value:
        return [Path(part) for part in value.split("\0") if part]
    return [Path(value)]


def query_zed_paths(db: Path, query: str) -> list[Path]:
    if not db.exists():
        return []
    paths: list[Path] = []
    try:
        connection = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
    except sqlite3.Error:
        return []
    try:
        for (value,) in connection.execute(query):
            paths.extend(split_zed_paths(value))
    except sqlite3.Error:
        return []
    finally:
        connection.close()
    return paths


def parse_zed_timestamp(value: str | None) -> float:
    if not value:
        return 0.0
    text = value.replace("Z", "+00:00")
    if "." in text:
        prefix, suffix = text.split(".", 1)
        timezone_start = max(suffix.find("+"), suffix.find("-"))
        if timezone_start == -1:
            fractional = suffix
            timezone_part = ""
        else:
            fractional = suffix[:timezone_start]
            timezone_part = suffix[timezone_start:]
        text = f"{prefix}.{fractional[:6]}{timezone_part}"
    try:
        parsed = datetime.fromisoformat(text)
    except ValueError:
        return 0.0
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=timezone.utc)
    return parsed.timestamp()


def zed_ai_thread_metadata(now: float | None = None) -> dict[str, dict[str, str | float]]:
    now = time.time() if now is None else now
    db = ZED_STATE_DIR / "db" / "0-stable" / "db.sqlite"
    if not db.exists():
        return {}
    try:
        connection = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
    except sqlite3.Error:
        return {}
    rows: list[tuple[str | None, str | None, str | None, str | None, str | None]] = []
    try:
        rows = connection.execute(
            """
            select folder_paths, updated_at, hex(thread_id), session_id, agent_id
            from sidebar_threads
            where archived = 0 and folder_paths is not null and folder_paths != ''
            order by updated_at desc
            """
        ).fetchall()
    except sqlite3.Error:
        return {}
    finally:
        connection.close()

    seen = load_ai_seen()
    by_project: dict[str, dict[str, str | float]] = {}
    for folders, updated_at, thread_id, session_id, agent_id in rows:
        updated_ts = parse_zed_timestamp(updated_at)
        for project in unique_existing(split_zed_paths(folders)):
            key = str(project)
            if key in by_project:
                continue
            seen_at = seen.get(key, "")
            state = "seen" if seen_at and seen_at >= str(updated_at) else "done"
            if updated_ts and now - updated_ts <= AI_RUNNING_WINDOW_SECONDS:
                state = "running"
            by_project[key] = {
                "state": state,
                "updated_at": str(updated_at),
                "updated_ts": updated_ts,
                "thread_id": str(thread_id or session_id or ""),
                "agent_id": str(agent_id or ""),
            }
    return by_project


def ai_badge(ai_state: dict[str, str | float] | None) -> str:
    if not ai_state:
        return "[AI:-]"
    state = ai_state.get("state")
    if state == "running":
        return "[AI:run]"
    if state == "done":
        return "[AI:done!]"
    if state == "seen":
        return "[AI:seen]"
    return "[AI:-]"


def mark_ai_seen_for_project(project: Path, ai_state: dict[str, str | float] | None) -> bool:
    if not ai_state or ai_state.get("state") != "done":
        return False
    updated_at = str(ai_state.get("updated_at", ""))
    if not updated_at:
        return False
    key = str(project.expanduser().resolve())
    seen = load_ai_seen()
    if seen.get(key) == updated_at:
        return False
    seen[key] = updated_at
    save_ai_seen(seen)
    ai_state["state"] = "seen"
    return True


def display_text(value: str) -> str:
    return "".join(ch if ch.isprintable() else "?" for ch in value)


def zed_thread_projects() -> list[Path]:
    paths: list[Path] = []
    paths.extend(
        query_zed_paths(
            ZED_STATE_DIR / "db" / "0-stable" / "db.sqlite",
            "select folder_paths from sidebar_threads where archived = 0 order by updated_at desc",
        )
    )
    paths.extend(
        query_zed_paths(
            ZED_STATE_DIR / "threads" / "threads.db",
            "select folder_paths from threads order by updated_at desc",
        )
    )
    paths.extend(
        query_zed_paths(
            ZED_STATE_DIR / "db" / "0-stable" / "db.sqlite",
            "select paths from workspaces order by timestamp desc limit 50",
        )
    )
    return unique_existing(paths)


def zed_remote_thread_specs() -> list[dict[str, str | int | None]]:
    db = ZED_STATE_DIR / "db" / "0-stable" / "db.sqlite"
    if not db.exists():
        return []
    try:
        connection = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
    except sqlite3.Error:
        return []
    try:
        rows = connection.execute(
            """
            select w.paths, rc.host, rc.user, rc.port
            from workspaces w
            join remote_connections rc on rc.id = w.remote_connection_id
            where w.paths is not null and w.paths != '' and rc.kind = 'ssh'
            order by w.timestamp desc
            """
        ).fetchall()
    except sqlite3.Error:
        return []
    finally:
        connection.close()

    seen: set[str] = set()
    specs: list[dict[str, str | int | None]] = []
    for paths_raw, host, user, port in rows:
        if not host:
            continue
        ssh_host = remote_host_label(str(user) if user else None, str(host), int(port) if port else None)
        for path in split_zed_paths(str(paths_raw)):
            remote_path = remote_path_key(str(path))
            key = remote_thread_key(ssh_host, remote_path)
            if key in seen:
                continue
            seen.add(key)
            specs.append(
                {
                    "host": ssh_host,
                    "path": remote_path,
                    "port": int(port) if port else None,
                }
            )
    return specs


def current_zed_project() -> Path | None:
    db = ZED_STATE_DIR / "db" / "0-stable" / "db.sqlite"
    if not db.exists():
        return None
    try:
        connection = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
    except sqlite3.Error:
        return None
    try:
        rows = connection.execute(
            """
            select paths, remote_connection_id, timestamp
            from workspaces
            where paths is not null and paths != '' and window_id is not null
            order by timestamp desc
            limit 20
            """
        ).fetchall()
    except sqlite3.Error:
        return None
    finally:
        connection.close()
    if not rows:
        return None
    latest_timestamp = rows[0][2]
    latest_rows = [row for row in rows if row[2] == latest_timestamp]
    if len(latest_rows) != 1:
        return None
    paths_raw, remote_connection_id, _timestamp = latest_rows[0]
    if remote_connection_id is not None:
        return None
    existing = unique_existing(split_zed_paths(str(paths_raw)))
    return existing[0] if existing else None


def current_zed_remote_key() -> str | None:
    db = ZED_STATE_DIR / "db" / "0-stable" / "db.sqlite"
    if not db.exists():
        return None
    try:
        connection = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
    except sqlite3.Error:
        return None
    try:
        rows = connection.execute(
            """
            select w.paths, w.remote_connection_id, rc.host, rc.user, rc.port, w.timestamp
            from workspaces w
            left join remote_connections rc on rc.id = w.remote_connection_id
            where w.paths is not null and w.paths != '' and w.window_id is not null
            order by w.timestamp desc
            limit 20
            """
        ).fetchall()
    except sqlite3.Error:
        return None
    finally:
        connection.close()
    if not rows:
        return None
    latest_timestamp = rows[0][5]
    latest_rows = [row for row in rows if row[5] == latest_timestamp]
    if len(latest_rows) != 1:
        return None
    paths_raw, remote_connection_id, host, user, port, _timestamp = latest_rows[0]
    if remote_connection_id is None or not host:
        return None
    ssh_host = remote_host_label(str(user) if user else None, str(host), int(port) if port else None)
    paths = split_zed_paths(str(paths_raw))
    if len(paths) != 1:
        return None
    return remote_thread_key(ssh_host, str(paths[0]))


def default_projects(cwd: Path, sync_zed: bool) -> list[Path]:
    registered = load_projects()
    zed_projects = zed_thread_projects() if sync_zed else []
    discovered = discover_worktrees(cwd)
    hidden = hidden_projects()
    hidden_keys = hidden_thread_keys()
    return [
        project
        for project in unique_existing([*registered, *zed_projects, *discovered])
        if project not in hidden and str(project) not in hidden_keys
    ]


def unique_existing(paths: Iterable[Path]) -> list[Path]:
    seen: set[Path] = set()
    result: list[Path] = []
    for path in paths:
        resolved = path.expanduser().resolve()
        try:
            is_dir = resolved.exists() and resolved.is_dir()
        except OSError:
            is_dir = False
        if resolved in seen or not is_dir:
            continue
        seen.add(resolved)
        result.append(resolved)
    return result


def command_for_project(project: Path, command: str) -> list[str]:
    if (project / "flake.nix").exists():
        return ["nix", "develop", "--command", "bash", "-lc", command]
    if (project / "shell.nix").exists() or (project / "default.nix").exists():
        return ["nix-shell", "--run", command]
    return ["bash", "-lc", command]


def warm_command_for_project(project: Path) -> list[str] | None:
    if (project / "flake.nix").exists():
        return ["nix", "develop", "--command", "true"]
    if (project / "shell.nix").exists() or (project / "default.nix").exists():
        return ["nix-shell", "--run", "true"]
    return None


def nix_wrapper_kind(project: Path) -> str:
    if (project / "flake.nix").exists():
        return "flake"
    if (project / "shell.nix").exists() or (project / "default.nix").exists():
        return "shell"
    return "none"


def focus_project_in_zed(project: Path, focus_limit: int = MAX_FOCUSED_WORKTREES) -> tuple[str, list[Path]]:
    popped = record_focused_project(project, limit=focus_limit)
    try:
        subprocess.Popen(
            ["zed", "--existing", str(project)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
        )
    except OSError as error:
        return f"zed focus failed: {error}", popped
    if popped:
        names = ", ".join(path.name for path in popped)
        return f"focused zed: {project.name}; focus cap dropped {names}", popped
    return f"focused zed: {project.name}", popped


def focus_project_in_rider(project: Path) -> tuple[subprocess.Popen[bytes] | None, str]:
    try:
        process = subprocess.Popen(
            ["rider", str(project)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
        )
    except OSError as error:
        return None, f"rider focus failed: {error}"
    return process, f"focused rider: {project.name}"


def set_open_threads_menu_on_focus(enabled: bool) -> dict[str, object]:
    config = load_config()
    config["open_threads_menu_on_focus"] = enabled
    save_config(config)
    return config


def load_ssh_connections() -> list[dict[str, object]]:
    raw = load_config().get("ssh_connections", [])
    if not isinstance(raw, list):
        return []
    connections: list[dict[str, object]] = []
    for entry in raw:
        if not isinstance(entry, dict):
            continue
        name = str(entry.get("name", "")).strip()
        command = str(entry.get("command", "")).strip()
        if name and command:
            connection: dict[str, object] = {"name": name, "command": command}
            if bool(entry.get("auto_start", False)):
                connection["auto_start"] = True
            connections.append(connection)
    return connections


def ssh_connection_name_from_command(command: str) -> str:
    try:
        argv = shlex.split(command)
    except ValueError:
        return "ssh-connection"
    destination = next((part for part in reversed(argv[1:]) if not part.startswith("-") and ":" not in part), "")
    if not destination:
        destination = "ssh-connection"
    name = "".join(ch if ch.isalnum() or ch in "._@-" else "-" for ch in destination)
    return name.strip("-") or "ssh-connection"


def ssh_connection_runtime_argv(command: str) -> list[str]:
    argv = shlex.split(command)
    if not argv or argv[0] != "ssh":
        return argv
    if "-N" in argv:
        return argv
    has_forward = any(arg in ("-L", "-R", "-D") or arg.startswith(("-L", "-R", "-D")) for arg in argv[1:])
    if not has_forward:
        return argv
    return [argv[0], "-N", *argv[1:]]


def save_ssh_connections(connections: list[dict[str, object]]) -> None:
    config = load_config()
    normalized: list[dict[str, object]] = []
    for entry in connections:
        name = str(entry.get("name", "")).strip()
        command = str(entry.get("command", "")).strip()
        if not name or not command:
            continue
        connection: dict[str, object] = {"name": name, "command": command}
        if bool(entry.get("auto_start", False)):
            connection["auto_start"] = True
        normalized.append(connection)
    config["ssh_connections"] = normalized
    save_config(config)


def load_thread_ssh_dependencies() -> dict[str, str]:
    raw = load_config().get("thread_ssh_dependencies", {})
    if not isinstance(raw, dict):
        return {}
    return {str(key): str(value) for key, value in raw.items() if str(key).strip() and str(value).strip()}


def save_thread_ssh_dependencies(dependencies: dict[str, str]) -> None:
    config = load_config()
    config["thread_ssh_dependencies"] = {str(key): str(value) for key, value in dependencies.items() if str(value).strip()}
    save_config(config)


def set_thread_ssh_dependency(thread_key: str, connection_name: str | None) -> dict[str, str]:
    dependencies = load_thread_ssh_dependencies()
    if connection_name:
        dependencies[thread_key] = connection_name
    else:
        dependencies.pop(thread_key, None)
    save_thread_ssh_dependencies(dependencies)
    return dependencies


def ssh_connection_log_path(name: str) -> Path:
    safe = "".join(ch if ch.isalnum() or ch in "._-" else "_" for ch in name)
    return state_dir() / "logs" / f"ssh_{safe}.log"


def zed_focus_binding(task_name: str, open_threads_menu: bool) -> list[object]:
    task_binding: list[object] = ["task::Spawn", {"task_name": task_name}]
    if not open_threads_menu:
        return task_binding
    return [
        "action::Sequence",
        [
            task_binding,
            "agent::ToggleFocus",
            "agents_sidebar::ToggleThreadSwitcher",
        ],
    ]


@dataclass
class ThreadCommand:
    project: Path
    command: str
    remote_host: str | None = None
    remote_path: str | None = None
    remote_port: int | None = None
    alias: str | None = None
    process: subprocess.Popen[bytes] | None = None
    slot_processes: dict[str, subprocess.Popen[bytes]] = field(default_factory=dict)
    warm_process: subprocess.Popen[bytes] | None = None
    registered_pgid: int | None = None
    registered_pid: int | None = None
    running_slot: str = "manual"
    last_status: str = "idle"
    last_exit: int | None = None

    @property
    def key(self) -> str:
        if self.is_remote:
            return remote_thread_key(str(self.remote_host), str(self.remote_path))
        return str(self.project)

    @property
    def name(self) -> str:
        if self.alias:
            return self.alias
        return self.base_name

    @property
    def base_name(self) -> str:
        if self.is_remote:
            remote_name = Path(str(self.remote_path)).name or str(self.remote_path)
            return f"{self.remote_host}:{remote_name}"
        return self.project.name or str(self.project)

    @property
    def is_remote(self) -> bool:
        return self.remote_host is not None and self.remote_path is not None

    @property
    def log_path(self) -> Path:
        safe = "".join(ch if ch.isalnum() or ch in "._-" else "_" for ch in self.key)
        return state_dir() / "logs" / f"{safe}.log"

    def poll(self) -> None:
        live_slots: list[str] = []
        for slot, process in list(self.slot_processes.items()):
            exit_code = process.poll()
            if exit_code is None:
                live_slots.append(slot)
                continue
            self.last_exit = exit_code
            self.slot_processes.pop(slot, None)
            unregister_process_key(self.key, slot)
        if self.process is not None:
            exit_code = self.process.poll()
            if exit_code is not None:
                self.last_exit = exit_code
                self.last_status = f"exited {exit_code}"
                self.process = None
                self.running_slot = "manual"
                unregister_process_key(self.key)
        elif self.registered_pgid is not None:
            if is_pgid_alive(self.registered_pgid):
                self.last_status = "running"
            else:
                self.registered_pgid = None
                self.registered_pid = None
                self.running_slot = "manual"
                self.last_status = "exited ?"
                unregister_process_key(self.key)
        elif live_slots:
            self.running_slot = ",".join(sorted(live_slots))
            self.last_status = "running"
        else:
            self.refresh_registered_processes()
        if self.warm_process is not None:
            exit_code = self.warm_process.poll()
            if exit_code is not None:
                self.last_status = "nix warmed" if exit_code == 0 else f"warm failed {exit_code}"
                self.warm_process = None

    def refresh_registered_processes(self) -> None:
        entries = process_entries_for_thread(load_processes(), self.key)
        live: list[tuple[str, dict[str, int | str]]] = []
        for process_key, data in entries.items():
            pgid = data.get("pgid")
            if isinstance(pgid, int) and is_pgid_alive(pgid):
                live.append((process_key, data))
                continue
            unregister_process_key(process_key)
        if not live:
            if self.last_status == "running":
                self.last_status = "exited ?"
            self.registered_pgid = None
            self.registered_pid = None
            self.running_slot = "manual"
            return
        slots = sorted(str(data.get("command_slot", "manual")) for _, data in live)
        primary = live[0][1]
        self.registered_pgid = primary.get("pgid") if isinstance(primary.get("pgid"), int) else None
        self.registered_pid = primary.get("pid") if isinstance(primary.get("pid"), int) else None
        self.running_slot = ",".join(slots)
        self.last_status = "running"

    def start(self, command_slot: str = "manual") -> None:
        if not self.command.strip():
            self.last_status = "missing command"
            return
        if command_slot in ("1", "2"):
            self.stop_slot(command_slot)
        else:
            self.stop()
        nix_kind = "auto"
        if self.is_remote:
            self.last_status = "detecting nix"
            nix_kind = detect_remote_nix_kind(str(self.remote_host), str(self.remote_path), self.remote_port)
        self.log_path.parent.mkdir(parents=True, exist_ok=True)
        compact_log_file(self.log_path)
        with self.log_path.open("ab", buffering=0) as log:
            header = f"\n[{time.strftime('%Y-%m-%d %H:%M:%S')}] {self.command}\n".encode()
            log.write(header)
            popen_cwd = None if self.is_remote else self.project
            process = subprocess.Popen(
                self.command_argv(nix_kind),
                cwd=popen_cwd,
                stdout=log,
                stderr=subprocess.STDOUT,
                stdin=subprocess.DEVNULL,
                preexec_fn=os.setsid,
            )
            if command_slot in ("1", "2"):
                self.slot_processes[command_slot] = process
            else:
                self.process = process
            register_process_key(self.key, process, self.command, command_slot)
        self.last_status = "running"
        self.running_slot = command_slot
        self.last_exit = None

    def command_argv(self, nix_kind: str = "auto") -> list[str]:
        if self.is_remote:
            return remote_command_for_project(str(self.remote_host), str(self.remote_path), self.command, self.remote_port, nix_kind)
        return command_for_project(self.project, self.command)

    def warm(self) -> None:
        if self.is_remote:
            if self.warm_process is not None and self.warm_process.poll() is None:
                self.last_status = "warming"
                return
            self.last_status = "detecting nix"
            nix_kind = detect_remote_nix_kind(str(self.remote_host), str(self.remote_path), self.remote_port)
            warm_command = remote_warm_command_for_project(str(self.remote_host), str(self.remote_path), self.remote_port, nix_kind)
            if warm_command is None:
                self.last_status = "no nix shell"
                return
            self.log_path.parent.mkdir(parents=True, exist_ok=True)
            compact_log_file(self.log_path)
            with self.log_path.open("ab", buffering=0) as log:
                log.write(f"\n[{time.strftime('%Y-%m-%d %H:%M:%S')}] warming remote nix shell ({nix_kind})\n".encode())
                self.warm_process = subprocess.Popen(
                    warm_command,
                    stdout=log,
                    stderr=subprocess.STDOUT,
                    stdin=subprocess.DEVNULL,
                    preexec_fn=os.setsid,
                )
            self.last_status = "warming"
            return
        warm_command = warm_command_for_project(self.project)
        if warm_command is None:
            self.last_status = "no nix shell"
            return
        if self.warm_process is not None and self.warm_process.poll() is None:
            self.last_status = "warming"
            return
        self.log_path.parent.mkdir(parents=True, exist_ok=True)
        compact_log_file(self.log_path)
        with self.log_path.open("ab", buffering=0) as log:
            log.write(f"\n[{time.strftime('%Y-%m-%d %H:%M:%S')}] warming nix shell\n".encode())
            self.warm_process = subprocess.Popen(
                warm_command,
                cwd=self.project,
                stdout=log,
                stderr=subprocess.STDOUT,
                stdin=subprocess.DEVNULL,
                preexec_fn=os.setsid,
            )
        self.last_status = "warming"

    def stop(self) -> None:
        self.stop_warm()
        for slot in list(self.slot_processes):
            self.stop_slot(slot)
        if self.registered_pgid is not None:
            for _process_key, data in process_entries_for_thread(load_processes(), self.key).items():
                pgid = data.get("pgid")
                if isinstance(pgid, int):
                    stop_process_group(pgid)
            self.registered_pgid = None
            self.registered_pid = None
            self.running_slot = "manual"
            unregister_process_key(self.key)
            self.last_status = "stopped"
            return
        if self.process is None or self.process.poll() is not None:
            self.process = None
            return
        try:
            os.killpg(os.getpgid(self.process.pid), signal.SIGTERM)
        except ProcessLookupError:
            self.process = None
            return
        deadline = time.monotonic() + 1.5
        while time.monotonic() < deadline:
            if self.process.poll() is not None:
                break
            time.sleep(0.05)
        if self.process.poll() is None:
            try:
                os.killpg(os.getpgid(self.process.pid), signal.SIGKILL)
            except ProcessLookupError:
                pass
        self.last_exit = self.process.poll()
        self.process = None
        self.running_slot = "manual"
        unregister_process_key(self.key)
        self.last_status = "stopped"

    def stop_slot(self, command_slot: str) -> None:
        process = self.slot_processes.pop(command_slot, None)
        if process is not None and process.poll() is None:
            try:
                stop_process_group(os.getpgid(process.pid))
            except ProcessLookupError:
                pass
        data = load_processes().get(command_process_key(self.key, command_slot))
        pgid = data.get("pgid") if data else None
        if isinstance(pgid, int):
            stop_process_group(pgid)
        unregister_process_key(self.key, command_slot)

    def stop_warm(self) -> None:
        if self.warm_process is None or self.warm_process.poll() is not None:
            self.warm_process = None
            return
        try:
            os.killpg(os.getpgid(self.warm_process.pid), signal.SIGTERM)
        except ProcessLookupError:
            self.warm_process = None
            return
        deadline = time.monotonic() + 1.5
        while time.monotonic() < deadline:
            if self.warm_process.poll() is not None:
                break
            time.sleep(0.05)
        if self.warm_process.poll() is None:
            try:
                os.killpg(os.getpgid(self.warm_process.pid), signal.SIGKILL)
            except ProcessLookupError:
                pass
        self.warm_process = None


class RunnerUi:
    def __init__(
        self,
        threads: list[ThreadCommand],
        focus_zed_on_run: bool,
        focus_limit: int,
        sort_mode: str,
        cwd: Path | None = None,
        default_command: str | None = None,
    ) -> None:
        self.threads = threads
        self.slots = ensure_slot_keys(thread.key for thread in threads)
        self.cwd = cwd or Path.cwd().resolve()
        self.default_command = default_command
        self.focus_zed_on_run = focus_zed_on_run
        self.focus_limit = focus_limit
        self.selected = 0
        self.filter_query = ""
        self.show_log = False
        self.show_details = False
        self.sort_mode = sort_mode if sort_mode in SORT_MODES else "source"
        self.compact = bool(load_config().get("compact", False))
        self.show_cmd2_in_rows = bool(load_config().get("show_cmd2_in_rows", False))
        self.multi_command_mode = bool(load_config().get("multi_command_mode", False))
        self.leader_key = str(load_config().get("leader_key", "space"))
        self.trust_zed_focus = bool(load_config().get("trust_zed_focus", False))
        self.leader_active = False
        self.leader_slot_digits = ""
        self.leader_pending_action = ""
        self.pending_row_action = ""
        self.message = "enter edit | / filter | o sort | !/@ cmd1/2 run | f focus | s run | q quit"
        self.commands = load_commands()
        self.command_slots = load_command_slots()
        self.presets = load_presets()
        self.aliases = load_aliases()
        self.thread_ssh_dependencies = load_thread_ssh_dependencies()
        self.pinned_projects = pinned_projects()
        self.ai_states: dict[str, dict[str, str | float]] = {}
        self.ai_states_checked_at = 0.0
        self.focused_project: Path | None = None
        self.focused_project_checked_at = 0.0
        self.focused_remote_key: str | None = None
        self.focused_remote_checked_at = 0.0
        self.rider_processes: dict[str, subprocess.Popen[bytes]] = {}
        self.ssh_processes: dict[str, subprocess.Popen[bytes]] = {}

    def run(self, stdscr: curses.window) -> None:
        curses.curs_set(0)
        self.init_colors()
        stdscr.nodelay(True)
        stdscr.keypad(True)
        self.auto_start_ssh_connections()
        while True:
            for thread in self.threads:
                thread.poll()
            self.draw(stdscr)
            key = stdscr.getch()
            if key == -1:
                time.sleep(0.1)
                continue
            if key in (ord("q"), 27):
                self.stop_warm_processes()
                self.stop_all_rider_processes()
                return
            if key == ord("Q"):
                self.stop_all()
                self.stop_all_rider_processes()
                self.stop_all_ssh_connections()
                return
            self.handle_key(stdscr, key)

    def draw(self, stdscr: curses.window) -> None:
        stdscr.erase()
        height, width = stdscr.getmaxyx()
        if height <= 0 or width <= 0:
            return
        title = "Zed thread runner"
        self.write_line(stdscr, 0, title, curses.A_REVERSE)
        focused_project = self.cached_focused_project()
        focused_remote_key = self.cached_focused_remote_key()
        ai_states = self.cached_ai_states()
        self.auto_mark_focused_ai_seen(focused_project, ai_states)

        visible_indices = self.visible_indices(focused_project, ai_states)
        list_height = max(0, height - 3)
        if self.show_log and height >= 8:
            list_height = max(3, height // 2 - 2)
        if self.show_details and height >= 8:
            list_height = max(3, height // 2 - 2)

        for row, thread_idx in enumerate(visible_indices[:list_height]):
            thread = self.threads[thread_idx]
            marker = ">" if thread_idx == self.selected else " "
            token = self.thread_token(thread, focused_project, focused_remote_key)
            command = self.row_command_text(thread)
            status = display_text(thread.last_status)
            slot = format_slot(self.slots.get(thread.key))
            if self.compact:
                line = self.compact_row(marker, slot, token, thread, status, command, ai_states.get(thread.key))
            else:
                line = f"{marker} {slot} {token} {thread.name:<22} {status:<12} {command}"
                line = self.with_right_badge(line, ai_badge(ai_states.get(thread.key)), max(1, width - 1))
            attr = self.row_attr(thread, thread_idx == self.selected, focused_project, focused_remote_key, ai_states.get(thread.key))
            self.write_line(stdscr, row + 1, line, attr)

        if self.show_log and height >= 8:
            log_start = list_height + 2
            self.write_line(stdscr, log_start - 1, f"log: {self.current.log_path}", curses.A_REVERSE)
            for offset, line in enumerate(self.tail_log(max(1, height - log_start - 2))):
                self.write_line(stdscr, log_start + offset, line)
        elif self.show_details and height >= 8:
            details_start = list_height + 2
            self.write_line(stdscr, details_start - 1, f"details: {self.current.name}", curses.A_REVERSE)
            for offset, line in enumerate(self.thread_details(self.current)[: max(1, height - details_start - 2)]):
                self.write_line(stdscr, details_start + offset, line)

        if height >= 2:
            leader_state = "on" if self.leader_active else "off"
            pending = self.leader_slot_digits or "-"
            leader_action = self.leader_pending_action or "-"
            suffix = f" leader={self.leader_key}:{leader_state} slot={pending} action={leader_action} filter={self.filter_query or '-'} sort={self.sort_mode} view={'compact' if self.compact else 'normal'}"
            status_attr = curses.A_REVERSE if self.leader_active else curses.A_DIM
            self.write_line(stdscr, height - 2, f"{self.message} |{suffix}", status_attr)
            buttons = "[Focus:f] [Run:s !/@] [Cmd:e/s/P] [Reload:R] [Settings:g/G] [SSH:D] [Proc:O] [Stop:x/a] [Log:t/L] [Info:i] [Quit:q/Q]"
            self.write_line(stdscr, height - 1, buttons, curses.A_REVERSE)
        stdscr.refresh()

    def write_line(self, stdscr: curses.window, row: int, text: str, attr: int = curses.A_NORMAL) -> None:
        height, width = stdscr.getmaxyx()
        if row < 0 or row >= height or width <= 0:
            return
        limit = width - 1
        if limit <= 0:
            return
        text = display_text(text)
        try:
            stdscr.addnstr(row, 0, text.ljust(limit), limit, attr)
        except curses.error:
            pass

    def compact_row(
        self,
        marker: str,
        slot: str,
        token: str,
        thread: ThreadCommand,
        status: str,
        command: str,
        ai_state: dict[str, str | float] | None = None,
    ) -> str:
        name = self.compact_name(thread)
        short_status = self.short_status(status)
        short_command = self.compact_command(command)
        flags = self.compact_flags(token, ai_state)
        return f"{marker}{slot}{flags} {name:<10} {short_status:<4} {short_command}"

    def row_command_text(self, thread: ThreadCommand) -> str:
        slots = command_slot_state(thread.key, self.command_slots)
        primary = slots.get("cmd1") or thread.command.strip() or "<cmd>"
        active = self.display_command_slot(thread)
        primary = self.active_command_text(primary, active == "1")
        if not self.multi_command_mode or not self.show_cmd2_in_rows:
            return display_text(primary)
        secondary = slots.get("cmd2") or "<cmd2>"
        secondary = self.active_command_text(secondary, active == "2")
        return display_text(f"{primary}  {secondary}")

    def active_command_text(self, command: str, active: bool) -> str:
        return f"[{command}]" if active else command

    def display_command_slot(self, thread: ThreadCommand) -> str:
        if self.is_running(thread) and thread.running_slot in ("1", "2"):
            return thread.running_slot
        return active_command_slot(thread.key, thread.command, self.command_slots)

    def command_slot_label(self, thread: ThreadCommand) -> str:
        active = active_command_slot(thread.key, thread.command, self.command_slots)
        if active in ("1", "2"):
            return f"c{active}"
        return "cm" if thread.command.strip() else "c-"

    def command_slot_status(self, thread: ThreadCommand, slot: int) -> str:
        slots = command_slot_state(thread.key, self.command_slots)
        command = slots.get(f"cmd{slot}", "")
        if not command:
            return "empty"
        processes = load_processes()
        process_data = processes.get(command_process_key(thread.key, str(slot)), {})
        if not process_data:
            process_data = next(
                (data for data in process_entries_for_thread(processes, thread.key).values() if str(data.get("command_slot")) == str(slot)),
                {},
            )
        pgid = process_data.get("pgid")
        if isinstance(pgid, int) and is_pgid_alive(pgid):
            pid = process_data.get("pid", "-")
            return f"running pid={pid} pgid={pgid}"
        process = thread.slot_processes.get(str(slot))
        if process is not None and process.poll() is None:
            try:
                return f"running pid={process.pid} pgid={os.getpgid(process.pid)}"
            except ProcessLookupError:
                return f"running pid={process.pid}"
        active = active_command_slot(thread.key, thread.command, self.command_slots)
        if active == str(slot):
            return "active"
        return "idle"

    def compact_name(self, thread: ThreadCommand) -> str:
        name = display_text(thread.name)
        return name[:10] if len(name) > 10 else name

    def compact_flags(self, token: str, ai_state: dict[str, str | float] | None = None) -> str:
        chars = token.ljust(5)
        run = chars[0]
        focus = "@" if "@" in chars else "-"
        pin = "^" if "^" in chars else "-"
        env = "R" if "R" in chars else "F" if "F" in chars else "S" if "S" in chars else "-"
        nix = "N" if "N" in chars else "-"
        ai = self.compact_ai(ai_state)
        return f"{run}{focus}{pin}{env}{nix}{ai}"

    def compact_ai(self, ai_state: dict[str, str | float] | None) -> str:
        state = ai_state.get("state") if ai_state else None
        return {"running": "a", "done": "!", "seen": "."}.get(str(state), "-")

    def compact_command(self, command: str) -> str:
        if command == "<enter command>" or not command:
            return "<cmd>"
        replacements = {
            "npm run ": "npm:",
            "pnpm ": "pn:",
            "yarn ": "yrn:",
            "cargo ": "cg:",
            "nix develop": "nixdev",
            "just ": "j:",
        }
        compact = command
        for prefix, replacement in replacements.items():
            if compact.startswith(prefix):
                compact = replacement + compact.removeprefix(prefix)
                break
        return compact[:28]

    def short_status(self, status: str) -> str:
        if status == "running":
            return "run"
        if status == "idle":
            return "idl"
        if status == "warming" or status.startswith("nix warmed") or status.startswith("detecting"):
            return "wrm"
        if status == "stopped":
            return "stp"
        if status == "missing command":
            return "mis"
        if status.startswith("exited 0"):
            return "ok"
        if status.startswith("exited") or status.startswith("warm failed"):
            return "bad"
        if status == "no nix shell":
            return "non"
        return status[:3] if status else "-"

    def init_colors(self) -> None:
        try:
            has_colors = curses.has_colors()
        except curses.error:
            has_colors = False
        if not has_colors:
            return
        try:
            curses.start_color()
            curses.use_default_colors()
            curses.init_pair(COLOR_DEFAULT, -1, -1)
            curses.init_pair(COLOR_RUNNING, curses.COLOR_GREEN, -1)
            curses.init_pair(COLOR_FAILED, curses.COLOR_RED, -1)
            curses.init_pair(COLOR_WARMING, curses.COLOR_CYAN, -1)
            curses.init_pair(COLOR_PINNED, curses.COLOR_YELLOW, -1)
            curses.init_pair(COLOR_REMOTE, curses.COLOR_BLUE, -1)
            curses.init_pair(COLOR_AI_DONE, curses.COLOR_MAGENTA, -1)
            curses.init_pair(COLOR_FOCUSED, curses.COLOR_BLACK, curses.COLOR_CYAN)
        except curses.error:
            pass

    def color_attr(self, color_pair: int) -> int:
        try:
            has_colors = curses.has_colors()
        except curses.error:
            has_colors = False
        if not has_colors:
            return curses.A_NORMAL
        try:
            return curses.color_pair(color_pair)
        except curses.error:
            return curses.A_NORMAL

    def row_attr(
        self,
        thread: ThreadCommand,
        selected: bool,
        focused_project: Path | None,
        focused_remote_key: str | None,
        ai_state: dict[str, str | float] | None,
    ) -> int:
        attr = self.thread_state_attr(thread, focused_project, focused_remote_key, ai_state)
        if selected:
            attr |= curses.A_REVERSE
        return attr

    def thread_state_attr(
        self,
        thread: ThreadCommand,
        focused_project: Path | None = None,
        focused_remote_key: str | None = None,
        ai_state: dict[str, str | float] | None = None,
    ) -> int:
        if focused_project == thread.project or focused_remote_key == thread.key:
            return self.color_attr(COLOR_FOCUSED) | curses.A_BOLD
        if self.is_failed(thread):
            return self.color_attr(COLOR_FAILED) | curses.A_BOLD
        if self.is_running(thread) and thread.warm_process is not None and thread.warm_process.poll() is None:
            return self.color_attr(COLOR_WARMING) | curses.A_BOLD
        if self.is_running(thread):
            return self.color_attr(COLOR_RUNNING) | curses.A_BOLD
        if ai_state and ai_state.get("state") == "done":
            return self.color_attr(COLOR_AI_DONE) | curses.A_BOLD
        if self.is_pinned(thread):
            return self.color_attr(COLOR_PINNED) | curses.A_BOLD
        if thread.is_remote:
            return self.color_attr(COLOR_REMOTE)
        return curses.A_NORMAL

    def thread_token(self, thread: ThreadCommand, focused_project: Path | None, focused_remote_key: str | None = None) -> str:
        run = "*"
        if thread.warm_process is not None and thread.warm_process.poll() is None:
            run = "~"
        elif thread.process is not None and thread.process.poll() is None:
            run = "*"
        elif thread.last_status.startswith(("exited 0", "idle", "nix warmed")):
            run = "."
        elif thread.last_status in ("stopped", "missing command") or thread.last_status.startswith(("exited", "warm failed")):
            run = "!"
        focused = "@" if (focused_project == thread.project or focused_remote_key == thread.key) else " "
        pinned = "^" if self.is_pinned(thread) else " "
        wrapper = "R" if thread.is_remote else {"flake": "F", "shell": "S", "none": "-"}[nix_wrapper_kind(thread.project)]
        active = "N" if wrapper != "-" and run in ("*", "~") else " "
        return f"{run}{focused}{pinned}{wrapper}{active}"

    def cached_focused_project(self) -> Path | None:
        if not self.trust_zed_focus:
            return self.focused_project
        now = time.monotonic()
        if now - self.focused_project_checked_at >= ZED_STATE_REFRESH_SECONDS:
            focused_project = current_zed_project()
            if focused_project is not None:
                self.focused_project = focused_project
                self.focused_remote_key = None
            self.focused_project_checked_at = now
        return self.focused_project

    def cached_focused_remote_key(self) -> str | None:
        if not self.trust_zed_focus:
            return self.focused_remote_key
        now = time.monotonic()
        if now - self.focused_remote_checked_at >= ZED_STATE_REFRESH_SECONDS:
            focused_remote_key = current_zed_remote_key()
            if focused_remote_key is not None:
                self.focused_remote_key = focused_remote_key
                self.focused_project = None
            self.focused_remote_checked_at = now
        return self.focused_remote_key

    def cached_ai_states(self) -> dict[str, dict[str, str | float]]:
        now = time.monotonic()
        if now - self.ai_states_checked_at >= ZED_STATE_REFRESH_SECONDS:
            self.ai_states = zed_ai_thread_metadata()
            self.ai_states_checked_at = now
        return self.ai_states

    def with_right_badge(self, left: str, badge: str, width: int) -> str:
        if width <= len(badge) + 2:
            return left
        left_limit = max(0, width - len(badge) - 2)
        left = left[:left_limit]
        gap = max(1, width - len(left) - len(badge) - 1)
        return f"{left}{' ' * gap}{badge}"

    def auto_mark_focused_ai_seen(
        self,
        focused_project: Path | None,
        ai_states: dict[str, dict[str, str | float]],
    ) -> None:
        if focused_project is None:
            return
        if mark_ai_seen_for_project(focused_project, ai_states.get(str(focused_project))):
            self.message = f"AI auto-seen: {focused_project.name}"

    def handle_key(self, stdscr: curses.window, key: int) -> None:
        if self.pending_row_action:
            self.handle_pending_row_action(stdscr, key)
            return
        if self.is_leader_key(key):
            self.leader_active = not self.leader_active
            self.leader_slot_digits = ""
            self.leader_pending_action = ""
            self.message = f"leader active: use <id>{self.leader_action_help()}" if self.leader_active else "leader off"
            return
        if self.leader_active:
            self.handle_leader_key(stdscr, key)
            return
        if key in (curses.KEY_UP, ord("k")):
            self.move_selection(-1)
        elif key in (curses.KEY_DOWN, ord("j")):
            self.move_selection(1)
        elif key in (curses.KEY_ENTER, 10, 13):
            self.edit_command(stdscr)
        elif key == ord("e"):
            if self.multi_command_mode:
                self.pending_row_action = "e"
                self.message = "edit command slot: 1 cmd1 | 2 cmd2 | q cancel"
            else:
                self.edit_command(stdscr)
        elif key == ord("/"):
            self.set_filter(stdscr)
        elif key == ord("u"):
            self.filter_query = ""
            self.message = "filter cleared"
        elif key == ord("o"):
            self.cycle_sort()
        elif key == ord("v"):
            self.toggle_compact()
        elif key == ord("t"):
            self.show_log = not self.show_log
            if self.show_log:
                self.show_details = False
            self.message = "log tail shown" if self.show_log else "log tail hidden"
        elif key == ord("i"):
            self.show_details = not self.show_details
            if self.show_details:
                self.show_log = False
            self.message = "details shown" if self.show_details else "details hidden"
        elif key == ord("g"):
            self.settings_menu(stdscr)
        elif key == ord("G"):
            self.ssh_connections_menu(stdscr)
        elif key == ord("O"):
            self.process_dashboard(stdscr)
        elif key == ord("c"):
            self.cycle_preset()
        elif key == ord("C"):
            self.pick_command_history(stdscr)
        elif key == ord("P"):
            self.save_current_command_slot(stdscr)
        elif key in (ord("1"), ord("2")):
            if self.multi_command_mode:
                self.message = "use e1/e2 to edit or s1/s2 to run command slots"
            else:
                self.message = "multi-command mode is off"
        elif key == ord("!"):
            self.use_command_slot(1, run=True, stop_all_first=False) if self.multi_command_mode else self.simple_mode_message()
        elif key == ord("@"):
            self.use_command_slot(2, run=True, stop_all_first=False) if self.multi_command_mode else self.simple_mode_message()
        elif key == ord("h"):
            self.hide_current()
        elif key == ord("H"):
            self.unhide_menu(stdscr)
        elif key == ord("p"):
            self.add_project(stdscr)
        elif key == ord("n"):
            self.alias_current(stdscr)
        elif key == ord("b"):
            self.toggle_pin_current()
        elif key == ord("D"):
            self.set_ssh_dependency_menu(stdscr)
        elif key == ord("s"):
            if self.multi_command_mode:
                self.pending_row_action = "s"
                self.message = "run command slot: 1 cmd1 | 2 cmd2 | q cancel"
            else:
                self.start_current(stop_all_first=False)
        elif key == ord("r"):
            self.start_current(stop_all_first=True)
        elif key == ord("R"):
            self.reload_threads_from_zed()
        elif key == ord("x"):
            self.current.stop()
        elif key == ord("a"):
            self.stop_all()
            self.message = "stopped all running commands"
        elif key == ord("w"):
            self.current.warm()
        elif key == ord("W"):
            for thread in self.threads:
                thread.warm()
            self.message = "warming all nix shells"
        elif key == ord("l"):
            self.message = f"log: {self.current.log_path}"
        elif key == ord("L"):
            self.clear_current_log()
        elif key in (ord("f"), ord("z")):
            self.focus_current()
        elif key == ord("F"):
            self.focus_current_rider()
        elif key == ord("A"):
            self.mark_ai_seen(self.current)
        elif key == ord("U"):
            self.mark_ai_unseen(self.current)
        elif key == ord("M"):
            self.mark_all_ai_seen()

    def handle_pending_row_action(self, stdscr: curses.window, key: int) -> None:
        action = self.pending_row_action
        if key in (27, ord("q")):
            self.pending_row_action = ""
            self.message = f"{action} cancelled"
            return
        if key not in (ord("1"), ord("2")):
            self.message = f"{action}: press 1 or 2, q cancels"
            return
        slot = int(chr(key))
        self.pending_row_action = ""
        if action == "e":
            self.edit_command_slot(stdscr, slot)
            return
        if action == "s":
            self.use_command_slot(slot, run=True, stop_all_first=False)
            return

    def simple_mode_message(self) -> None:
        self.message = "multi-command mode is off"

    def is_leader_key(self, key: int) -> bool:
        if self.leader_key in ("space", "Space", "<space>", "<leader>"):
            return key == ord(" ")
        return len(self.leader_key) == 1 and key == ord(self.leader_key)

    def handle_leader_key(self, stdscr: curses.window, key: int) -> None:
        if self.leader_pending_action in ("e", "s", "R"):
            if key in (ord("1"), ord("2")):
                if not self.leader_slot_digits:
                    self.message = f"leader needs slot number first, e.g. <leader>9{self.leader_pending_action}1"
                    return
                slot = int(self.leader_slot_digits)
                action = f"{self.leader_pending_action}{chr(key)}"
                if action in ("e1", "e2", "s1", "s2", "R1", "R2") and not self.multi_command_mode:
                    self.message = "multi-command mode is off"
                    self.leader_active = False
                    self.leader_slot_digits = ""
                    self.leader_pending_action = ""
                    return
                self.run_leader_slot_action(stdscr, slot, action)
                self.leader_active = False
                self.leader_slot_digits = ""
                self.leader_pending_action = ""
                return
            if key in (27, ord("q")):
                self.leader_active = False
                self.leader_slot_digits = ""
                self.leader_pending_action = ""
                self.message = "leader off"
                return
            self.message = f"leader slot {self.leader_slot_digits} {self.leader_pending_action}: 1 cmd1 | 2 cmd2"
            return
        if ord("0") <= key <= ord("9"):
            self.leader_slot_digits += chr(key)
            self.message = f"leader slot {self.leader_slot_digits}: {self.leader_action_help()}"
            return
        if key in (ord("e"), ord("s"), ord("R")):
            if not self.multi_command_mode:
                self.message = "multi-command mode is off"
                return
            if not self.leader_slot_digits:
                self.message = f"leader needs slot number first, e.g. <leader>9{chr(key)}1"
                return
            self.leader_pending_action = chr(key)
            self.message = f"leader slot {self.leader_slot_digits} {chr(key)}: 1 cmd1 | 2 cmd2"
            return
        if key in self.leader_action_keys():
            if not self.leader_slot_digits:
                self.message = "leader needs slot number first, e.g. <leader>9e"
                return
            slot = int(self.leader_slot_digits)
            self.run_leader_slot_action(stdscr, slot, chr(key))
            self.leader_active = False
            self.leader_slot_digits = ""
            self.leader_pending_action = ""
            return
        if key in (27, ord("q")):
            self.leader_active = False
            self.leader_slot_digits = ""
            self.leader_pending_action = ""
            self.message = "leader off"
            return
        self.message = f"leader: use digits then {self.leader_action_help()}, or leader again to cancel"

    def leader_action_keys(self) -> tuple[int, ...]:
        return tuple(ord(action) for action in "frFxah!@")

    def leader_action_help(self) -> str:
        return "e1/e2 edit | s1/s2 run | f/F/r/x/a/h | !/@ run | R1/R2 stop+run"

    def run_leader_slot_action(self, stdscr: curses.window, slot: int, action: str) -> None:
        thread = self.thread_for_slot(slot)
        if thread is None:
            self.message = f"slot {slot} not found"
            return
        self.selected = self.threads.index(thread)
        if action == "e1":
            self.edit_command_slot(stdscr, 1)
        elif action == "e2":
            self.edit_command_slot(stdscr, 2)
        elif action == "f":
            self.focus_current()
        elif action == "F":
            self.focus_current_rider()
        elif action == "r":
            self.start_current(stop_all_first=True)
        elif action == "s1":
            self.use_command_slot(1, run=True, stop_all_first=False)
        elif action == "s2":
            self.use_command_slot(2, run=True, stop_all_first=False)
        elif action == "!":
            self.use_command_slot(1, run=True, stop_all_first=False) if self.multi_command_mode else self.simple_mode_message()
        elif action == "@":
            self.use_command_slot(2, run=True, stop_all_first=False) if self.multi_command_mode else self.simple_mode_message()
        elif action == "R1":
            self.use_command_slot(1, run=True, stop_all_first=True)
        elif action == "R2":
            self.use_command_slot(2, run=True, stop_all_first=True)
        elif action == "x":
            thread.stop()
            self.message = f"stopped slot {slot}: {thread.name}"
        elif action == "a":
            self.stop_all()
            self.message = f"stopped all from slot {slot}: {thread.name}"
        elif action == "h":
            self.hide_current()

    def thread_for_slot(self, slot: int) -> ThreadCommand | None:
        for thread in self.threads:
            if self.slots.get(thread.key) == slot:
                return thread
        return None

    @property
    def current(self) -> ThreadCommand:
        return self.threads[self.selected]

    def visible_indices(
        self,
        focused_project: Path | None = None,
        ai_states: dict[str, dict[str, str | float]] | None = None,
    ) -> list[int]:
        ai_states = ai_states or self.ai_states
        query = self.filter_query.casefold()
        indices = [
            idx
            for idx, thread in enumerate(self.threads)
            if not query or query in thread.name.casefold() or query in str(thread.project).casefold()
        ]
        if self.sort_mode == "source":
            return sorted(indices, key=lambda idx: (self.pin_priority(self.threads[idx]), idx))
        if self.sort_mode == "name":
            return sorted(indices, key=lambda idx: (self.pin_priority(self.threads[idx]), self.threads[idx].name.casefold()))
        if self.sort_mode == "running":
            return sorted(
                indices,
                key=lambda idx: (
                    self.pin_priority(self.threads[idx]),
                    not self.is_running(self.threads[idx]),
                    self.threads[idx].name.casefold(),
                ),
            )
        if self.sort_mode == "failed":
            return sorted(
                indices,
                key=lambda idx: (
                    self.pin_priority(self.threads[idx]),
                    not self.is_failed(self.threads[idx]),
                    self.threads[idx].name.casefold(),
                ),
            )
        if self.sort_mode == "focused":
            return sorted(
                indices,
                key=lambda idx: (
                    self.pin_priority(self.threads[idx]),
                    self.threads[idx].project != focused_project,
                    self.threads[idx].name.casefold(),
                ),
            )
        if self.sort_mode == "ai":
            return sorted(
                indices,
                key=lambda idx: (
                    self.pin_priority(self.threads[idx]),
                    self.ai_priority(self.threads[idx], ai_states),
                    self.threads[idx].name.casefold(),
                ),
            )
        return indices

    def ai_priority(self, thread: ThreadCommand, ai_states: dict[str, dict[str, str | float]]) -> int:
        state = ai_states.get(thread.key, {}).get("state")
        return {"running": 0, "done": 1, "seen": 2}.get(str(state), 3)

    def is_pinned(self, thread: ThreadCommand) -> bool:
        return thread.project.expanduser().resolve() in self.pinned_projects

    def pin_priority(self, thread: ThreadCommand) -> int:
        return 0 if self.is_pinned(thread) else 1

    def is_running(self, thread: ThreadCommand) -> bool:
        return (
            (thread.process is not None and thread.process.poll() is None)
            or any(process.poll() is None for process in thread.slot_processes.values())
            or (thread.registered_pgid is not None and is_pgid_alive(thread.registered_pgid))
            or any(isinstance(data.get("pgid"), int) and is_pgid_alive(int(data["pgid"])) for data in process_entries_for_thread(load_processes(), thread.key).values())
            or (thread.warm_process is not None and thread.warm_process.poll() is None)
        )

    def is_failed(self, thread: ThreadCommand) -> bool:
        return thread.last_status == "missing command" or thread.last_status.startswith(("exited", "warm failed"))

    def move_selection(self, delta: int) -> None:
        visible = self.visible_indices(self.cached_focused_project(), self.cached_ai_states())
        if not visible:
            return
        if self.selected not in visible:
            self.selected = visible[0]
            return
        pos = visible.index(self.selected)
        self.selected = visible[max(0, min(len(visible) - 1, pos + delta))]

    def cycle_sort(self) -> None:
        pos = SORT_MODES.index(self.sort_mode) if self.sort_mode in SORT_MODES else 0
        self.sort_mode = SORT_MODES[(pos + 1) % len(SORT_MODES)]
        config = load_config()
        config["sort_mode"] = self.sort_mode
        save_config(config)
        self.message = f"sort: {self.sort_mode}"

    def toggle_compact(self) -> None:
        self.compact = not self.compact
        config = load_config()
        config["compact"] = self.compact
        save_config(config)
        self.message = f"view: {'compact' if self.compact else 'normal'}"

    def settings_entries(self) -> list[tuple[str, str]]:
        return [
            ("compact", f"compact rows: {'on' if self.compact else 'off'}"),
            ("multi_command_mode", f"multi-command mode: {'on' if self.multi_command_mode else 'off'}"),
            ("show_cmd2_in_rows", f"show cmd2 in rows: {'on' if self.show_cmd2_in_rows else 'off'}"),
            ("focus_zed_on_run", f"focus Zed before run: {'on' if self.focus_zed_on_run else 'off'}"),
            ("trust_zed_focus", f"trust Zed DB focus polling: {'on' if self.trust_zed_focus else 'off'}"),
            (
                "open_threads_menu_on_focus",
                f"generated focus opens threads menu: {'on' if bool(load_config().get('open_threads_menu_on_focus', False)) else 'off'}",
            ),
            ("sort_mode", f"sort mode: {self.sort_mode}"),
            ("focus_limit", f"focus cap: {self.focus_limit}"),
            ("leader_key", f"leader key: {self.leader_key}"),
        ]

    def settings_menu(self, stdscr: curses.window) -> None:
        selected = 0
        stdscr.nodelay(False)
        try:
            while True:
                entries = self.settings_entries()
                stdscr.erase()
                height, width = stdscr.getmaxyx()
                self.write_line(stdscr, 0, "settings: enter toggle/edit | q close", curses.A_REVERSE)
                list_height = max(0, height - 2)
                start = max(0, selected - max(0, list_height - 1))
                for row, (_, label) in enumerate(entries[start : start + list_height]):
                    index = start + row
                    marker = ">" if index == selected else " "
                    attr = curses.A_REVERSE if index == selected else curses.A_NORMAL
                    self.write_line(stdscr, row + 1, f"{marker} {label}"[: max(1, width - 1)], attr)
                stdscr.refresh()
                key = stdscr.getch()
                if key in (ord("q"), 27):
                    self.message = "settings closed"
                    return
                if key in (curses.KEY_UP, ord("k")):
                    selected = max(0, selected - 1)
                    continue
                if key in (curses.KEY_DOWN, ord("j")):
                    selected = min(len(entries) - 1, selected + 1)
                    continue
                if key in (curses.KEY_ENTER, 10, 13, ord(" ")):
                    self.apply_setting(stdscr, entries[selected][0])
        finally:
            stdscr.nodelay(True)

    def ssh_connections_menu(self, stdscr: curses.window) -> None:
        selected = 0
        stdscr.nodelay(False)
        try:
            while True:
                connections = load_ssh_connections()
                entries = [
                    f"{entry['name']} [{'run' if self.is_ssh_connection_running(str(entry['name'])) else 'idle'}]"
                    f"{' auto' if bool(entry.get('auto_start', False)) else ''}"
                    for entry in connections
                ]
                entries.append("+ add connection")
                stdscr.erase()
                height, width = stdscr.getmaxyx()
                self.write_line(stdscr, 0, "ssh: enter start/stop | A auto | a add | d delete | q close", curses.A_REVERSE)
                list_height = max(0, height - 2)
                selected = min(selected, max(0, len(entries) - 1))
                start = max(0, selected - max(0, list_height - 1))
                for row, label in enumerate(entries[start : start + list_height]):
                    index = start + row
                    marker = ">" if index == selected else " "
                    attr = curses.A_REVERSE if index == selected else curses.A_NORMAL
                    self.write_line(stdscr, row + 1, f"{marker} {label}"[: max(1, width - 1)], attr)
                stdscr.refresh()
                key = stdscr.getch()
                if key in (ord("q"), 27):
                    self.message = "ssh menu closed"
                    return
                if key in (curses.KEY_UP, ord("k")):
                    selected = max(0, selected - 1)
                    continue
                if key in (curses.KEY_DOWN, ord("j")):
                    selected = min(len(entries) - 1, selected + 1)
                    continue
                if key == ord("a") or (key in (curses.KEY_ENTER, 10, 13) and selected == len(connections)):
                    self.add_ssh_connection(stdscr)
                    selected = len(load_ssh_connections())
                    continue
                if key == ord("d") and selected < len(connections):
                    self.delete_ssh_connection(str(connections[selected]["name"]))
                    selected = max(0, selected - 1)
                    continue
                if key == ord("A") and selected < len(connections):
                    self.toggle_ssh_auto_start(str(connections[selected]["name"]))
                    continue
                if key in (curses.KEY_ENTER, 10, 13) and selected < len(connections):
                    self.toggle_ssh_connection(connections[selected])
        finally:
            stdscr.nodelay(True)

    def add_ssh_connection(self, stdscr: curses.window) -> None:
        first = self.read_prompt(stdscr, "ssh name or command: ", "").strip()
        if not first:
            self.message = "ssh add cancelled"
            return
        if first.startswith("ssh "):
            command = first
            name = ssh_connection_name_from_command(command)
        else:
            name = first
            command = self.read_prompt(stdscr, "ssh command: ", "").strip()
            if not command:
                self.message = "ssh command empty"
                return
        try:
            argv = shlex.split(command)
        except ValueError as error:
            self.message = f"invalid ssh command: {error}"
            return
        if not argv or argv[0] != "ssh":
            self.message = "ssh command must start with ssh"
            return
        connections = [entry for entry in load_ssh_connections() if entry["name"] != name]
        connections.append({"name": name, "command": command})
        save_ssh_connections(connections)
        self.message = f"saved ssh: {name}"

    def delete_ssh_connection(self, name: str) -> None:
        self.stop_ssh_connection(name)
        save_ssh_connections([entry for entry in load_ssh_connections() if entry["name"] != name])
        self.message = f"deleted ssh: {name}"

    def toggle_ssh_auto_start(self, name: str) -> None:
        connections = []
        enabled = False
        for entry in load_ssh_connections():
            if entry["name"] == name:
                entry = dict(entry)
                enabled = not bool(entry.get("auto_start", False))
                if enabled:
                    entry["auto_start"] = True
                else:
                    entry.pop("auto_start", None)
            connections.append(entry)
        save_ssh_connections(connections)
        self.message = f"ssh auto-start {name}: {'on' if enabled else 'off'}"

    def toggle_ssh_connection(self, connection: dict[str, object]) -> None:
        name = str(connection["name"])
        if self.is_ssh_connection_running(name):
            self.stop_ssh_connection(name)
            self.message = f"stopped ssh: {name}"
            return
        self.start_ssh_connection(connection)

    def start_ssh_connection(self, connection: dict[str, object], quiet: bool = False) -> bool:
        name = str(connection["name"])
        command = str(connection["command"])
        try:
            argv = ssh_connection_runtime_argv(command)
        except ValueError as error:
            if not quiet:
                self.message = f"invalid ssh command {name}: {error}"
            return False
        if not argv or argv[0] != "ssh":
            if not quiet:
                self.message = f"ssh command must start with ssh: {name}"
            return False
        if self.is_ssh_connection_running(name):
            if not quiet:
                self.message = f"ssh already running: {name}"
            return True
        log_path = ssh_connection_log_path(name)
        log_path.parent.mkdir(parents=True, exist_ok=True)
        compact_log_file(log_path)
        with log_path.open("ab", buffering=0) as log:
            log.write(f"\n[{time.strftime('%Y-%m-%d %H:%M:%S')}] {command}\n".encode())
            try:
                process = subprocess.Popen(
                    argv,
                    stdout=log,
                    stderr=subprocess.STDOUT,
                    stdin=subprocess.DEVNULL,
                    preexec_fn=os.setsid,
                )
            except OSError as error:
                if not quiet:
                    self.message = f"ssh start failed {name}: {error}"
                return False
        self.ssh_processes[name] = process
        register_process_key(ssh_process_key(name), process, command, "manual")
        if not quiet:
            self.message = f"started ssh: {name}"
        return True

    def auto_start_ssh_connections(self) -> None:
        started = 0
        for connection in load_ssh_connections():
            name = str(connection["name"])
            if bool(connection.get("auto_start", False)) and not self.is_ssh_connection_running(name):
                if self.start_ssh_connection(connection, quiet=True):
                    started += 1
        if started:
            self.message = f"auto-started {started} ssh connection(s)"

    def is_ssh_connection_running(self, name: str) -> bool:
        process = self.ssh_processes.get(name)
        if process is not None and process.poll() is None:
            return True
        data = load_processes().get(ssh_process_key(name))
        pgid = data.get("pgid") if data else None
        if isinstance(pgid, int) and is_pgid_alive(pgid):
            return True
        if data:
            unregister_process_key(ssh_process_key(name))
        return False

    def stop_ssh_connection(self, name: str) -> None:
        process = self.ssh_processes.pop(name, None)
        if process is None or process.poll() is not None:
            data = load_processes().get(ssh_process_key(name))
            pgid = data.get("pgid") if data else None
            if isinstance(pgid, int):
                stop_process_group(pgid)
            unregister_process_key(ssh_process_key(name))
            return
        try:
            os.killpg(os.getpgid(process.pid), signal.SIGTERM)
        except ProcessLookupError:
            unregister_process_key(ssh_process_key(name))
            return
        deadline = time.monotonic() + 1.5
        while time.monotonic() < deadline:
            if process.poll() is not None:
                unregister_process_key(ssh_process_key(name))
                return
            time.sleep(0.05)
        if process.poll() is None:
            try:
                os.killpg(os.getpgid(process.pid), signal.SIGKILL)
            except ProcessLookupError:
                pass
        unregister_process_key(ssh_process_key(name))

    def stop_all_ssh_connections(self) -> None:
        names = {str(entry["name"]) for entry in load_ssh_connections()}
        names.update(self.ssh_processes)
        for name in list(names):
            self.stop_ssh_connection(name)

    def ssh_connection_by_name(self, name: str) -> dict[str, object] | None:
        for connection in load_ssh_connections():
            if connection["name"] == name:
                return connection
        return None

    def ensure_thread_ssh_dependency(self, thread: ThreadCommand) -> bool:
        name = self.thread_ssh_dependencies.get(thread.key, "")
        if not name:
            return True
        connection = self.ssh_connection_by_name(name)
        if connection is None:
            thread.last_status = "missing ssh dependency"
            self.message = f"missing ssh dependency {name}: {thread.name}"
            return False
        if self.is_ssh_connection_running(name):
            return True
        if not self.start_ssh_connection(connection, quiet=True):
            thread.last_status = "ssh dependency failed"
            self.message = f"failed ssh dependency {name}: {thread.name}"
            return False
        return True

    def set_ssh_dependency_menu(self, stdscr: curses.window) -> None:
        connections = load_ssh_connections()
        entries = ["<none>", *[str(entry["name"]) for entry in connections]]
        choice = self.choose_entry(stdscr, f"ssh dependency: {self.current.name}", entries)
        if choice is None:
            self.message = "ssh dependency unchanged"
            return
        if choice == "<none>":
            self.thread_ssh_dependencies = set_thread_ssh_dependency(self.current.key, None)
            self.message = f"cleared ssh dependency: {self.current.name}"
            return
        self.thread_ssh_dependencies = set_thread_ssh_dependency(self.current.key, choice)
        self.message = f"ssh dependency {self.current.name}: {choice}"

    def apply_setting(self, stdscr: curses.window, setting: str) -> None:
        config = load_config()
        if setting == "compact":
            self.compact = not self.compact
            config["compact"] = self.compact
            save_config(config)
            self.message = f"compact: {'on' if self.compact else 'off'}"
            return
        if setting == "focus_zed_on_run":
            self.focus_zed_on_run = not self.focus_zed_on_run
            config["focus_zed_on_run"] = self.focus_zed_on_run
            save_config(config)
            self.message = f"focus Zed before run: {'on' if self.focus_zed_on_run else 'off'}"
            return
        if setting == "multi_command_mode":
            self.multi_command_mode = not self.multi_command_mode
            config["multi_command_mode"] = self.multi_command_mode
            if not self.multi_command_mode:
                self.pending_row_action = ""
            save_config(config)
            self.message = f"multi-command mode: {'on' if self.multi_command_mode else 'off'}"
            return
        if setting == "show_cmd2_in_rows":
            self.show_cmd2_in_rows = not self.show_cmd2_in_rows
            config["show_cmd2_in_rows"] = self.show_cmd2_in_rows
            save_config(config)
            self.message = f"show cmd2 in rows: {'on' if self.show_cmd2_in_rows else 'off'}"
            return
        if setting == "trust_zed_focus":
            self.trust_zed_focus = not self.trust_zed_focus
            config["trust_zed_focus"] = self.trust_zed_focus
            save_config(config)
            self.message = f"trust Zed focus: {'on' if self.trust_zed_focus else 'off'}"
            return
        if setting == "open_threads_menu_on_focus":
            enabled = not bool(config.get("open_threads_menu_on_focus", False))
            set_open_threads_menu_on_focus(enabled)
            self.message = f"focus keybinding opens threads menu: {'on' if enabled else 'off'}"
            return
        if setting == "sort_mode":
            self.cycle_sort()
            return
        if setting == "focus_limit":
            raw = self.read_prompt(stdscr, "focus cap: ", str(self.focus_limit))
            try:
                value = max(1, int(raw))
            except ValueError:
                self.message = "focus cap must be a positive integer"
                return
            self.focus_limit = value
            config["focus_limit"] = value
            save_config(config)
            self.message = f"focus cap: {value}"
            return
        if setting == "leader_key":
            value = self.read_prompt(stdscr, "leader key (space or single char): ", self.leader_key).strip()
            if not value:
                self.message = "leader key unchanged"
                return
            if value not in ("space", "Space", "<space>", "<leader>") and len(value) != 1:
                self.message = "leader key must be 'space' or one character"
                return
            self.leader_key = value
            config["leader_key"] = value
            save_config(config)
            self.message = f"leader key: {value}"

    def set_filter(self, stdscr: curses.window) -> None:
        self.filter_query = self.read_prompt(stdscr, "filter: ", self.filter_query)
        visible = self.visible_indices(self.cached_focused_project(), self.cached_ai_states())
        if visible:
            self.selected = visible[0]
        self.message = f"filter: {self.filter_query or '-'}"

    def edit_command(self, stdscr: curses.window) -> None:
        command = self.read_command_prompt(stdscr, self.current)
        if command:
            self.current.command = command
            self.persist_current()
            record_command_history(self.current.key, command)
            self.message = f"set {self.current.name}: {command}"

    def edit_command_slot(self, stdscr: curses.window, slot: int) -> None:
        slots = command_slot_state(self.current.key, self.command_slots)
        initial = slots.get(f"cmd{slot}", "")
        command = self.read_history_prompt(
            stdscr,
            f"cmd{slot} for {self.current.name}: ",
            initial,
            load_command_history().get(self.current.key, []),
            self.command_completions(self.current),
        )
        if not command:
            return
        active_before = active_command_slot(self.current.key, self.current.command, self.command_slots)
        state = save_thread_command_slot(self.current.key, slot, command, active=False)
        self.command_slots[self.current.key] = state
        if active_before == str(slot):
            self.current.command = command
            self.persist_current(active_slot=str(slot))
        record_command_history(self.current.key, command)
        self.message = f"set cmd{slot} {self.current.name}: {command}"

    def add_project(self, stdscr: curses.window) -> None:
        raw_path = self.read_prompt(stdscr, "project path: ", "")
        if not raw_path:
            return
        project = Path(raw_path).expanduser().resolve()
        if not project.exists() or not project.is_dir():
            self.message = f"not a directory: {project}"
            return
        projects = add_projects([project])
        if all(thread.project != project for thread in self.threads):
            command = load_commands().get(str(project), "")
            self.threads.append(ThreadCommand(project=project, command=command))
            self.slots = ensure_slot_keys(thread.key for thread in self.threads)
            self.selected = len(self.threads) - 1
        self.message = f"registered {project.name} ({len(projects)} total)"

    def hide_current(self) -> None:
        thread = self.current
        if thread.is_remote:
            hide_thread_keys([thread.key])
        else:
            hide_projects([thread.project])
        removed = thread.name
        self.threads.pop(self.selected)
        self.selected = min(self.selected, max(0, len(self.threads) - 1))
        self.message = f"hid {removed}"

    def unhide_menu(self, stdscr: curses.window) -> None:
        entries = hidden_thread_entries()
        if not entries:
            self.message = "no hidden threads"
            return
        choice = self.choose_entry(stdscr, "unhide thread", entries)
        if choice is None:
            self.message = "unhide cancelled"
            return
        unhide_thread_keys([choice])
        if not choice.startswith("ssh:"):
            try:
                unhide_projects([Path(choice)])
            except OSError:
                pass
        self.refresh_unhidden_thread(choice)
        self.message = f"unhid {choice}"

    def refresh_unhidden_thread(self, key: str) -> None:
        if any(thread.key == key for thread in self.threads):
            return
        if key.startswith("ssh:"):
            for thread in build_remote_threads(None):
                if thread.key == key:
                    self.threads.append(thread)
                    self.slots = ensure_slot_keys(thread.key for thread in self.threads)
                    self.selected = len(self.threads) - 1
                    return
            return
        project = Path(key).expanduser().resolve()
        if project.exists() and project.is_dir():
            command = load_commands().get(str(project), "")
            self.threads.append(ThreadCommand(project=project, command=command, alias=self.aliases.get(str(project))))
            self.slots = ensure_slot_keys(thread.key for thread in self.threads)
            self.selected = len(self.threads) - 1

    def reload_threads_from_zed(self) -> None:
        existing = {thread.key for thread in self.threads}
        added: list[ThreadCommand] = []

        zed_projects = zed_thread_projects()
        if zed_projects:
            add_projects(zed_projects)
        hidden = hidden_projects()
        hidden_keys = hidden_thread_keys()
        local_threads = build_threads(
            [project for project in zed_projects if project not in hidden and str(project) not in hidden_keys],
            self.default_command,
        )
        remote_threads = build_remote_threads(self.default_command)
        for thread in [*local_threads, *remote_threads]:
            if thread.key in existing:
                continue
            self.threads.append(thread)
            existing.add(thread.key)
            added.append(thread)

        if added:
            self.commands = load_commands()
            self.command_slots = load_command_slots()
            self.aliases = load_aliases()
            self.thread_ssh_dependencies = load_thread_ssh_dependencies()
            self.slots = ensure_slot_keys(thread.key for thread in self.threads)
            self.selected = self.threads.index(added[0])
        self.message = f"reloaded Zed threads: +{len(added)} ({len(self.threads)} total)"

    def alias_current(self, stdscr: curses.window) -> None:
        thread = self.current
        current_alias = thread.alias or ""
        prompt = f"alias for {thread.base_name}: "
        alias = self.read_prompt(stdscr, prompt, current_alias)
        self.aliases = set_thread_alias(thread.key, alias)
        thread.alias = self.aliases.get(thread.key)
        self.message = f"alias cleared: {thread.base_name}" if not thread.alias else f"alias {thread.base_name}: {thread.alias}"

    def toggle_pin_current(self) -> None:
        project = self.current.project.expanduser().resolve()
        if project in self.pinned_projects:
            unpin_projects([project])
            self.pinned_projects.discard(project)
            self.message = f"unpinned {self.current.name}"
            return
        pin_projects([project])
        self.pinned_projects.add(project)
        self.message = f"pinned {self.current.name}"

    def cycle_preset(self) -> None:
        project_presets = self.presets.get(self.current.key, {})
        if not project_presets:
            self.message = f"no presets for {self.current.name}"
            return
        names = sorted(project_presets)
        current_name = next((name for name in names if project_presets[name] == self.current.command), None)
        next_index = 0 if current_name is None else (names.index(current_name) + 1) % len(names)
        name = names[next_index]
        self.current.command = project_presets[name]
        self.persist_current()
        self.message = f"preset {name}: {self.current.command}"

    def pick_command_history(self, stdscr: curses.window) -> None:
        history = load_command_history().get(self.current.key, [])
        if not history:
            self.message = f"no command history for {self.current.name}"
            return
        command = self.choose_entry(stdscr, f"history: {self.current.name}", history)
        if command is None:
            self.message = "history cancelled"
            return
        self.current.command = command
        self.persist_current()
        record_command_history(self.current.key, command)
        self.message = f"history set {self.current.name}: {command}"

    def use_command_slot(self, slot: int, run: bool, stop_all_first: bool = False) -> None:
        command = command_for_slot(self.current.key, slot, self.command_slots)
        if not command:
            self.message = f"cmd{slot} empty for {self.current.name}"
            return
        self.current.command = command
        self.persist_current(active_slot=str(slot))
        if run:
            self.start_current(stop_all_first=stop_all_first, command_slot=str(slot))
            return
        self.message = f"active cmd{slot}: {self.current.name}"

    def save_current_command_slot(self, stdscr: curses.window) -> None:
        if not self.current.command.strip():
            self.message = "set a command before saving cmd1/cmd2"
            return
        slot_raw = self.read_prompt(stdscr, "save current command to cmd slot (1/2): ", "1")
        if slot_raw not in ("1", "2"):
            self.message = "command slot must be 1 or 2"
            return
        slot = int(slot_raw)
        state = save_thread_command_slot(self.current.key, slot, self.current.command, active=False)
        self.command_slots[self.current.key] = state
        self.message = f"saved cmd{slot}: {self.current.name}"

    def save_preset(self, stdscr: curses.window) -> None:
        if not self.current.command.strip():
            self.message = "set a command before saving a preset"
            return
        name = self.read_prompt(stdscr, "preset name: ", "")
        if not name:
            return
        project_presets = set_preset(self.current.project, name, self.current.command)
        self.presets[self.current.key] = project_presets
        self.message = f"saved preset {name}"

    def tail_log(self, line_count: int) -> list[str]:
        return tail_file_lines(self.current.log_path, line_count)

    def clear_current_log(self) -> None:
        if clear_log_file(self.current.log_path):
            self.message = f"cleared log: {self.current.name}"
            return
        self.message = f"failed to clear log: {self.current.name}"

    def thread_details(self, thread: ThreadCommand) -> list[str]:
        aliases = load_aliases()
        remote_focus = load_remote_focus_targets()
        remote_nix = load_remote_nix_cache()
        processes = load_processes()
        process_data = processes.get(thread.key, {})
        history_count = len(load_command_history().get(thread.key, []))
        slots = command_slot_state(thread.key, self.command_slots)
        dependency = self.thread_ssh_dependencies.get(thread.key, "-")
        dependency_state = "run" if dependency != "-" and self.is_ssh_connection_running(dependency) else "idle"
        details = [
            f"name: {thread.name}",
            f"base: {thread.base_name}",
            f"key: {thread.key}",
            f"alias: {aliases.get(thread.key, '-')}",
            f"command: {thread.command or '<empty>'}",
            f"active slot: {self.command_slot_label(thread)}",
            f"running slot: {thread.running_slot}",
            f"cmd1: {slots.get('cmd1') or '<empty>'}",
            f"cmd1 status: {self.command_slot_status(thread, 1)}",
            f"cmd2: {slots.get('cmd2') or '<empty>'}",
            f"cmd2 status: {self.command_slot_status(thread, 2)}",
            f"status: {thread.last_status}",
            f"pid/pgid: {process_data.get('pid', thread.registered_pid or '-')} / {process_data.get('pgid', thread.registered_pgid or '-')}",
            f"ssh dependency: {dependency} ({dependency_state if dependency != '-' else '-'})",
            f"history: {history_count} command(s)",
            f"log: {thread.log_path}",
        ]
        if thread.is_remote:
            details.extend(
                [
                    f"remote host: {thread.remote_host}",
                    f"remote path: {thread.remote_path}",
                    f"remote focus: {remote_focus.get(thread.key, remote_ssh_uri(str(thread.remote_host), str(thread.remote_path)))}",
                    f"remote nix: {remote_nix.get(thread.key, 'unknown')}",
                ]
            )
        else:
            details.append(f"project: {thread.project}")
            details.append(f"nix: {nix_wrapper_kind(thread.project)}")
        details.extend(f"log tail: {line}" for line in self.thread_log_preview(thread, 3))
        return details

    def thread_log_preview(self, thread: ThreadCommand, line_count: int) -> list[str]:
        return tail_file_lines(thread.log_path, line_count)

    def mark_ai_seen(self, thread: ThreadCommand) -> None:
        state = self.cached_ai_states().get(thread.key)
        if mark_ai_seen_for_project(thread.project, state):
            self.message = f"AI seen: {thread.name}"
            return
        if state is None:
            self.message = f"no AI state for {thread.name}"
            return
        self.message = f"AI already seen: {thread.name}"

    def mark_ai_unseen(self, thread: ThreadCommand) -> None:
        seen = load_ai_seen()
        if seen.pop(thread.key, None) is not None:
            save_ai_seen(seen)
        self.ai_states_checked_at = 0.0
        self.message = f"AI unchecked: {thread.name}"

    def mark_all_ai_seen(self) -> None:
        seen = load_ai_seen()
        count = 0
        for project, state in self.cached_ai_states().items():
            if state.get("state") == "done":
                seen[project] = str(state.get("updated_at", ""))
                count += 1
        save_ai_seen(seen)
        self.ai_states_checked_at = 0.0
        self.message = f"AI seen: {count} thread(s)"

    def read_prompt(self, stdscr: curses.window, prompt: str, initial: str) -> str:
        stdscr.nodelay(False)
        curses.echo()
        curses.curs_set(1)
        height, width = stdscr.getmaxyx()
        input_width = max(1, width - 1)
        if len(prompt) >= input_width:
            prompt = "> "
        self.write_line(stdscr, height - 1, "")
        try:
            stdscr.addnstr(height - 1, 0, prompt, input_width)
        except curses.error:
            pass
        stdscr.refresh()
        if initial:
            try:
                stdscr.addnstr(height - 1, len(prompt), initial, max(0, input_width - len(prompt)))
            except curses.error:
                pass
        try:
            raw = stdscr.getstr(height - 1, len(prompt), max(1, input_width - len(prompt)))
        finally:
            curses.noecho()
            curses.curs_set(0)
            stdscr.nodelay(True)
        return raw.decode(errors="replace").strip()

    def read_command_prompt(self, stdscr: curses.window, thread: ThreadCommand) -> str:
        history = load_command_history().get(thread.key, [])
        if thread.command and thread.command not in history:
            history = [thread.command, *history]
        prompt = f"command for {thread.name}: "
        return self.read_history_prompt(stdscr, prompt, thread.command, history, self.command_completions(thread))

    def command_completions(self, thread: ThreadCommand) -> list[str]:
        history = load_command_history().get(thread.key, [])
        slots = command_slot_state(thread.key, self.command_slots)
        slot_commands = [slots.get("cmd1", ""), slots.get("cmd2", "")]
        preset_commands = sorted(set(self.presets.get(thread.key, {}).values()))
        completions = []
        for command in [*slot_commands, thread.command, *history, *preset_commands]:
            if command and command not in completions:
                completions.append(command)
        return completions

    def read_history_prompt(
        self,
        stdscr: curses.window,
        prompt: str,
        initial: str,
        history: list[str],
        completions: list[str] | None = None,
    ) -> str:
        stdscr.nodelay(False)
        curses.noecho()
        curses.curs_set(1)
        height, width = stdscr.getmaxyx()
        input_width = max(1, width - 1)
        if len(prompt) >= input_width:
            prompt = "> "
        max_value_width = max(1, input_width - len(prompt))
        value = initial
        cursor = len(value)
        history_index: int | None = None
        completions = completions or history

        def redraw() -> None:
            shown = value[-max_value_width:]
            self.write_line(stdscr, height - 1, "")
            try:
                stdscr.addnstr(height - 1, 0, prompt, input_width)
                stdscr.addnstr(height - 1, len(prompt), shown, max_value_width)
                stdscr.move(height - 1, min(input_width - 1, len(prompt) + min(cursor, max_value_width)))
            except curses.error:
                pass
            stdscr.refresh()

        try:
            while True:
                redraw()
                key = stdscr.getch()
                if key in (curses.KEY_ENTER, 10, 13):
                    return value.strip()
                if key in (27,):
                    return initial.strip()
                if key in (9, curses.KEY_BTAB):
                    completed = complete_command_value(value[:cursor], completions)
                    if completed != value[:cursor]:
                        value = completed + value[cursor:]
                        cursor = len(completed)
                    continue
                if key in (curses.KEY_UP,):
                    if history:
                        history_index = 0 if history_index is None else min(len(history) - 1, history_index + 1)
                        value = history[history_index]
                        cursor = len(value)
                    continue
                if key in (curses.KEY_DOWN,):
                    if history_index is None:
                        continue
                    history_index -= 1
                    if history_index < 0:
                        history_index = None
                        value = initial
                    else:
                        value = history[history_index]
                    cursor = len(value)
                    continue
                if key in (curses.KEY_LEFT,):
                    cursor = max(0, cursor - 1)
                    continue
                if key in (curses.KEY_RIGHT,):
                    cursor = min(len(value), cursor + 1)
                    continue
                if key in (curses.KEY_HOME,):
                    cursor = 0
                    continue
                if key in (curses.KEY_END,):
                    cursor = len(value)
                    continue
                if key in (curses.KEY_BACKSPACE, 127, 8):
                    if cursor > 0:
                        value = value[: cursor - 1] + value[cursor:]
                        cursor -= 1
                    continue
                if key == curses.KEY_DC:
                    if cursor < len(value):
                        value = value[:cursor] + value[cursor + 1 :]
                    continue
                if 0 <= key <= 255 and chr(key).isprintable():
                    value = value[:cursor] + chr(key) + value[cursor:]
                    cursor += 1
        finally:
            curses.curs_set(0)
            stdscr.nodelay(True)

    def choose_entry(self, stdscr: curses.window, title: str, entries: list[str]) -> str | None:
        selected = 0
        stdscr.nodelay(False)
        try:
            while True:
                stdscr.erase()
                height, width = stdscr.getmaxyx()
                self.write_line(stdscr, 0, f"{title}: enter select | q cancel", curses.A_REVERSE)
                list_height = max(0, height - 2)
                start = max(0, selected - max(0, list_height - 1))
                for row, entry in enumerate(entries[start : start + list_height]):
                    index = start + row
                    marker = ">" if index == selected else " "
                    line = f"{marker} {index + 1:02d} {entry}"
                    attr = curses.A_REVERSE if index == selected else curses.A_NORMAL
                    self.write_line(stdscr, row + 1, line[: max(1, width - 1)], attr)
                stdscr.refresh()
                key = stdscr.getch()
                if key in (ord("q"), 27):
                    return None
                if key in (curses.KEY_ENTER, 10, 13):
                    return entries[selected]
                if key in (curses.KEY_UP, ord("k")):
                    selected = max(0, selected - 1)
                elif key in (curses.KEY_DOWN, ord("j")):
                    selected = min(len(entries) - 1, selected + 1)
        finally:
            stdscr.nodelay(True)

    def process_dashboard_entries(self) -> list[tuple[str, str]]:
        entries: list[tuple[str, str]] = []
        for key, data in sorted(load_processes().items()):
            pgid = data.get("pgid")
            pid = data.get("pid")
            slot = data.get("command_slot", "manual")
            status = "run" if isinstance(pgid, int) and is_pgid_alive(pgid) else "stale"
            kind = "ssh" if key.startswith("ssh-connection:") else "cmd"
            command = display_text(str(data.get("command", "")))[:48]
            entries.append((f"{kind:<5} {status:<5} pid={pid or '-'} pgid={pgid or '-'} slot={slot} {key} {command}", key))
        for thread in self.threads:
            if thread.warm_process is not None and thread.warm_process.poll() is None:
                entries.append((f"warm  run   pid={thread.warm_process.pid} pgid=- slot=- {thread.key}", f"warm:{thread.key}"))
        for key, process in sorted(self.rider_processes.items()):
            if process.poll() is None:
                entries.append((f"rider run   pid={process.pid} pgid=- slot=- {key}", f"rider:{key}"))
        return entries

    def process_dashboard(self, stdscr: curses.window) -> None:
        selected = 0
        stdscr.nodelay(False)
        try:
            while True:
                entries = self.process_dashboard_entries()
                stdscr.erase()
                height, width = stdscr.getmaxyx()
                self.write_line(stdscr, 0, "processes: enter stop | r refresh | q close", curses.A_REVERSE)
                if not entries:
                    self.write_line(stdscr, 1, "no tracked processes")
                    stdscr.refresh()
                    key = stdscr.getch()
                    if key in (ord("q"), 27, curses.KEY_ENTER, 10, 13):
                        self.message = "process dashboard closed"
                        return
                    continue
                selected = min(selected, len(entries) - 1)
                list_height = max(0, height - 2)
                start = max(0, selected - max(0, list_height - 1))
                for row, (label, _) in enumerate(entries[start : start + list_height]):
                    index = start + row
                    marker = ">" if index == selected else " "
                    attr = curses.A_REVERSE if index == selected else curses.A_NORMAL
                    self.write_line(stdscr, row + 1, f"{marker} {label}"[: max(1, width - 1)], attr)
                stdscr.refresh()
                key = stdscr.getch()
                if key in (ord("q"), 27):
                    self.message = "process dashboard closed"
                    return
                if key in (curses.KEY_UP, ord("k")):
                    selected = max(0, selected - 1)
                    continue
                if key in (curses.KEY_DOWN, ord("j")):
                    selected = min(len(entries) - 1, selected + 1)
                    continue
                if key == ord("r"):
                    continue
                if key in (curses.KEY_ENTER, 10, 13):
                    self.stop_process_entry(entries[selected][1])
                    entries = self.process_dashboard_entries()
                    selected = min(selected, max(0, len(entries) - 1))
        finally:
            stdscr.nodelay(True)

    def stop_process_entry(self, key: str) -> None:
        if key.startswith("ssh-connection:"):
            name = key.removeprefix("ssh-connection:")
            self.stop_ssh_connection(name)
            self.message = f"stopped ssh: {name}"
            return
        if key.startswith("warm:"):
            thread_key = key.removeprefix("warm:")
            thread = next((item for item in self.threads if item.key == thread_key), None)
            if thread is not None:
                thread.stop_warm()
            self.message = f"stopped warm: {thread_key}"
            return
        if key.startswith("rider:"):
            rider_key = key.removeprefix("rider:")
            self.stop_rider_process(rider_key)
            self.message = f"stopped rider: {rider_key}"
            return
        thread = next((item for item in self.threads if item.key == key), None)
        if thread is not None:
            thread.stop()
            self.message = f"stopped process: {thread.name}"
            return
        data = load_processes().get(key)
        pgid = data.get("pgid") if data else None
        if isinstance(pgid, int):
            stop_process_group(pgid)
        unregister_process_key(key)
        self.message = f"stopped process: {key}"

    def persist_current(self, active_slot: str | None = None) -> None:
        self.commands[self.current.key] = self.current.command
        save_commands(self.commands)
        if active_slot is None:
            active_slot = active_command_slot(self.current.key, self.current.command, self.command_slots)
        state = set_active_command_slot(self.current.key, active_slot)
        self.command_slots[self.current.key] = state

    def focus_current(self) -> None:
        if self.current.is_remote:
            ok, message = focus_remote_in_zed(str(self.current.remote_host), str(self.current.remote_path))
            self.focused_remote_key = self.current.key
            self.focused_project = None
            self.focused_remote_checked_at = time.monotonic()
            self.message = message if ok else f"{message}; runner focused {self.current.name}"
            return
        message, popped = focus_project_in_zed(self.current.project, focus_limit=self.focus_limit)
        self.focused_project = self.current.project
        self.focused_remote_key = None
        self.focused_project_checked_at = time.monotonic()
        self.auto_mark_focused_ai_seen(self.current.project, self.cached_ai_states())
        self.message = message

    def focus_current_rider(self) -> None:
        thread = self.current
        self.stop_unfocused_rider_processes(thread.key)
        if thread.is_remote:
            self.message = f"rider focus only supports local threads: {thread.name}"
            return
        existing = self.rider_processes.get(thread.key)
        if existing is not None and existing.poll() is None:
            self.message = f"rider already focused: {thread.name}"
            return
        process, message = focus_project_in_rider(thread.project)
        if process is not None:
            self.rider_processes[thread.key] = process
        self.message = message

    def stop_unfocused_rider_processes(self, focused_key: str) -> None:
        for key in list(self.rider_processes):
            if key != focused_key:
                self.stop_rider_process(key)

    def stop_all_rider_processes(self) -> None:
        for key in list(self.rider_processes):
            self.stop_rider_process(key)

    def stop_rider_process(self, key: str) -> None:
        process = self.rider_processes.pop(key, None)
        if process is None or process.poll() is not None:
            return
        try:
            os.killpg(os.getpgid(process.pid), signal.SIGTERM)
        except ProcessLookupError:
            return
        deadline = time.monotonic() + 1.5
        while time.monotonic() < deadline:
            if process.poll() is not None:
                return
            time.sleep(0.05)
        if process.poll() is None:
            try:
                os.killpg(os.getpgid(process.pid), signal.SIGKILL)
            except ProcessLookupError:
                pass

    def start_current(self, stop_all_first: bool, command_slot: str = "manual") -> None:
        thread = self.current
        if stop_all_first:
            self.stop_all()
        if not self.ensure_thread_ssh_dependency(thread):
            return
        if self.focus_zed_on_run:
            if thread.is_remote:
                ok, message = focus_remote_in_zed(str(thread.remote_host), str(thread.remote_path))
                self.focused_remote_key = thread.key
                self.focused_project = None
                self.focused_remote_checked_at = time.monotonic()
                self.message = message if ok else f"{message}; runner focused {thread.name}"
            else:
                message, popped = focus_project_in_zed(thread.project, focus_limit=self.focus_limit)
                self.focused_project = thread.project
                self.focused_remote_key = None
                self.focused_project_checked_at = time.monotonic()
                self.auto_mark_focused_ai_seen(thread.project, self.cached_ai_states())
                self.message = message
        thread.start(command_slot=command_slot)
        self.commands[thread.key] = thread.command
        save_commands(self.commands)
        active_slot = command_slot if command_slot in ("1", "2") else active_command_slot(thread.key, thread.command, self.command_slots)
        state = set_active_command_slot(thread.key, active_slot)
        self.command_slots[thread.key] = state
        record_command_history(thread.key, thread.command)
        prefix = "stopped all, " if stop_all_first else ""
        self.message = f"{prefix}running {thread.name}"

    def stop_all(self) -> None:
        for thread in self.threads:
            thread.stop()
        stop_all_registered_processes()

    def stop_warm_processes(self) -> None:
        for thread in self.threads:
            thread.stop_warm()


