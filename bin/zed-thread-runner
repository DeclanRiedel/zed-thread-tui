#!/usr/bin/env python3
"""Thin terminal UI for running per-worktree commands through nix shells."""

from __future__ import annotations

import argparse
import curses
import json
import os
import signal
import sqlite3
import subprocess
import sys
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Iterable


APP_NAME = "zed-thread-runner"
ZED_STATE_DIR = Path.home() / ".local" / "share" / "zed"
MAX_FOCUSED_WORKTREES = 4


def state_dir() -> Path:
    base = os.environ.get("XDG_STATE_HOME")
    if base:
        return Path(base) / APP_NAME
    return Path.home() / ".local" / "state" / APP_NAME


def load_commands() -> dict[str, str]:
    path = state_dir() / "commands.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    return {str(k): str(v) for k, v in data.items()}


def load_processes() -> dict[str, dict[str, int | str]]:
    path = state_dir() / "processes.json"
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}
    return {str(k): v for k, v in data.items() if isinstance(v, dict)}


def load_projects() -> list[Path]:
    path = state_dir() / "projects.json"
    if not path.exists():
        return []
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return []
    if not isinstance(data, list):
        return []
    return unique_existing(Path(str(project)) for project in data)


def load_focus_history() -> list[Path]:
    path = state_dir() / "focus-history.json"
    if not path.exists():
        return []
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return []
    if not isinstance(data, list):
        return []
    return unique_existing(Path(str(project)) for project in data)


def save_commands(commands: dict[str, str]) -> None:
    target = state_dir() / "commands.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(commands, indent=2, sort_keys=True) + "\n")


def save_projects(projects: list[Path]) -> None:
    target = state_dir() / "projects.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps([str(project) for project in projects], indent=2) + "\n")


def save_focus_history(projects: list[Path]) -> None:
    target = state_dir() / "focus-history.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps([str(project) for project in projects], indent=2) + "\n")


def add_projects(projects: Iterable[Path]) -> list[Path]:
    current = load_projects()
    merged = unique_existing([*current, *projects])
    save_projects(merged)
    return merged


def remove_projects(projects: Iterable[Path]) -> list[Path]:
    removed = {project.expanduser().resolve() for project in projects}
    kept = [project for project in load_projects() if project not in removed]
    save_projects(kept)
    return kept


def record_focused_project(project: Path, limit: int = MAX_FOCUSED_WORKTREES) -> list[Path]:
    resolved = project.expanduser().resolve()
    history = [resolved, *[entry for entry in load_focus_history() if entry != resolved]]
    kept = history[:limit]
    popped = history[limit:]
    save_focus_history(kept)
    if popped:
        remove_projects(popped)
    return popped


def save_processes(processes: dict[str, dict[str, int | str]]) -> None:
    target = state_dir() / "processes.json"
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(processes, indent=2, sort_keys=True) + "\n")


def register_process(project: Path, process: subprocess.Popen[bytes], command: str) -> None:
    processes = load_processes()
    try:
        pgid = os.getpgid(process.pid)
    except ProcessLookupError:
        return
    processes[str(project)] = {
        "pid": process.pid,
        "pgid": pgid,
        "command": command,
    }
    save_processes(processes)


def unregister_process(project: Path) -> None:
    processes = load_processes()
    if processes.pop(str(project), None) is not None:
        save_processes(processes)


def stop_process_group(pgid: int) -> None:
    try:
        os.killpg(pgid, signal.SIGTERM)
    except ProcessLookupError:
        return
    deadline = time.monotonic() + 1.5
    while time.monotonic() < deadline:
        try:
            os.killpg(pgid, 0)
        except ProcessLookupError:
            return
        time.sleep(0.05)
    try:
        os.killpg(pgid, signal.SIGKILL)
    except ProcessLookupError:
        pass


def stop_all_registered_processes() -> int:
    processes = load_processes()
    stopped = 0
    for data in processes.values():
        pgid = data.get("pgid")
        if isinstance(pgid, int):
            stop_process_group(pgid)
            stopped += 1
    save_processes({})
    return stopped


def discover_worktrees(cwd: Path) -> list[Path]:
    try:
        result = subprocess.run(
            ["git", "worktree", "list", "--porcelain"],
            cwd=cwd,
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except (OSError, subprocess.CalledProcessError):
        return [cwd]

    paths: list[Path] = []
    for line in result.stdout.splitlines():
        if line.startswith("worktree "):
            paths.append(Path(line.removeprefix("worktree ")).expanduser().resolve())
    return paths or [cwd]


def split_zed_paths(value: str | None) -> list[Path]:
    if not value:
        return []
    value = value.strip()
    if not value:
        return []
    try:
        parsed = json.loads(value)
    except json.JSONDecodeError:
        parsed = None
    if isinstance(parsed, list):
        return [Path(str(path)) for path in parsed if str(path)]
    if "\n" in value:
        return [Path(part) for part in value.splitlines() if part]
    if "\0" in value:
        return [Path(part) for part in value.split("\0") if part]
    return [Path(value)]


def query_zed_paths(db: Path, query: str) -> list[Path]:
    if not db.exists():
        return []
    paths: list[Path] = []
    try:
        connection = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
    except sqlite3.Error:
        return []
    try:
        for (value,) in connection.execute(query):
            paths.extend(split_zed_paths(value))
    except sqlite3.Error:
        return []
    finally:
        connection.close()
    return paths


def zed_thread_projects() -> list[Path]:
    paths: list[Path] = []
    paths.extend(
        query_zed_paths(
            ZED_STATE_DIR / "db" / "0-stable" / "db.sqlite",
            "select folder_paths from sidebar_threads where archived = 0 order by updated_at desc",
        )
    )
    paths.extend(
        query_zed_paths(
            ZED_STATE_DIR / "threads" / "threads.db",
            "select folder_paths from threads order by updated_at desc",
        )
    )
    paths.extend(
        query_zed_paths(
            ZED_STATE_DIR / "db" / "0-stable" / "db.sqlite",
            "select paths from workspaces order by timestamp desc limit 50",
        )
    )
    return unique_existing(paths)


def current_zed_project() -> Path | None:
    paths: list[Path] = []
    paths.extend(
        query_zed_paths(
            ZED_STATE_DIR / "db" / "0-stable" / "db.sqlite",
            "select paths from workspaces where paths is not null and paths != '' order by timestamp desc limit 1",
        )
    )
    paths.extend(
        query_zed_paths(
            ZED_STATE_DIR / "db" / "0-stable" / "db.sqlite",
            "select folder_paths from sidebar_threads where archived = 0 and folder_paths is not null and folder_paths != '' order by updated_at desc limit 1",
        )
    )
    existing = unique_existing(paths)
    return existing[0] if existing else None


def default_projects(cwd: Path, sync_zed: bool) -> list[Path]:
    registered = load_projects()
    zed_projects = zed_thread_projects() if sync_zed else []
    discovered = discover_worktrees(cwd)
    return unique_existing([*registered, *zed_projects, *discovered])


def unique_existing(paths: Iterable[Path]) -> list[Path]:
    seen: set[Path] = set()
    result: list[Path] = []
    for path in paths:
        resolved = path.expanduser().resolve()
        try:
            is_dir = resolved.exists() and resolved.is_dir()
        except OSError:
            is_dir = False
        if resolved in seen or not is_dir:
            continue
        seen.add(resolved)
        result.append(resolved)
    return result


def command_for_project(project: Path, command: str) -> list[str]:
    if (project / "flake.nix").exists():
        return ["nix", "develop", "--command", "bash", "-lc", command]
    if (project / "shell.nix").exists() or (project / "default.nix").exists():
        return ["nix-shell", "--run", command]
    return ["bash", "-lc", command]


def warm_command_for_project(project: Path) -> list[str] | None:
    if (project / "flake.nix").exists():
        return ["nix", "develop", "--command", "true"]
    if (project / "shell.nix").exists() or (project / "default.nix").exists():
        return ["nix-shell", "--run", "true"]
    return None


def focus_project_in_zed(project: Path) -> tuple[str, list[Path]]:
    popped = record_focused_project(project)
    try:
        subprocess.Popen(
            ["zed", "--existing", str(project)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            stdin=subprocess.DEVNULL,
            start_new_session=True,
        )
    except OSError as error:
        return f"zed focus failed: {error}", popped
    if popped:
        names = ", ".join(path.name for path in popped)
        return f"focused zed: {project.name}; popped {names}", popped
    return f"focused zed: {project.name}", popped


@dataclass
class ThreadCommand:
    project: Path
    command: str
    process: subprocess.Popen[bytes] | None = None
    warm_process: subprocess.Popen[bytes] | None = None
    last_status: str = "idle"
    last_exit: int | None = None

    @property
    def key(self) -> str:
        return str(self.project)

    @property
    def name(self) -> str:
        return self.project.name or str(self.project)

    @property
    def log_path(self) -> Path:
        safe = "".join(ch if ch.isalnum() or ch in "._-" else "_" for ch in self.key)
        return state_dir() / "logs" / f"{safe}.log"

    def poll(self) -> None:
        if self.process is not None:
            exit_code = self.process.poll()
            if exit_code is not None:
                self.last_exit = exit_code
                self.last_status = f"exited {exit_code}"
                self.process = None
                unregister_process(self.project)
        if self.warm_process is not None:
            exit_code = self.warm_process.poll()
            if exit_code is not None:
                self.last_status = "nix warmed" if exit_code == 0 else f"warm failed {exit_code}"
                self.warm_process = None

    def start(self) -> None:
        if not self.command.strip():
            self.last_status = "missing command"
            return
        self.stop()
        self.log_path.parent.mkdir(parents=True, exist_ok=True)
        with self.log_path.open("ab", buffering=0) as log:
            header = f"\n[{time.strftime('%Y-%m-%d %H:%M:%S')}] {self.command}\n".encode()
            log.write(header)
            self.process = subprocess.Popen(
                command_for_project(self.project, self.command),
                cwd=self.project,
                stdout=log,
                stderr=subprocess.STDOUT,
                stdin=subprocess.DEVNULL,
                preexec_fn=os.setsid,
            )
            register_process(self.project, self.process, self.command)
        self.last_status = "running"
        self.last_exit = None

    def warm(self) -> None:
        warm_command = warm_command_for_project(self.project)
        if warm_command is None:
            self.last_status = "no nix shell"
            return
        if self.warm_process is not None and self.warm_process.poll() is None:
            self.last_status = "warming"
            return
        self.log_path.parent.mkdir(parents=True, exist_ok=True)
        with self.log_path.open("ab", buffering=0) as log:
            log.write(f"\n[{time.strftime('%Y-%m-%d %H:%M:%S')}] warming nix shell\n".encode())
            self.warm_process = subprocess.Popen(
                warm_command,
                cwd=self.project,
                stdout=log,
                stderr=subprocess.STDOUT,
                stdin=subprocess.DEVNULL,
                preexec_fn=os.setsid,
            )
        self.last_status = "warming"

    def stop(self) -> None:
        if self.process is None or self.process.poll() is not None:
            self.process = None
            return
        try:
            os.killpg(os.getpgid(self.process.pid), signal.SIGTERM)
        except ProcessLookupError:
            self.process = None
            return
        deadline = time.monotonic() + 1.5
        while time.monotonic() < deadline:
            if self.process.poll() is not None:
                break
            time.sleep(0.05)
        if self.process.poll() is None:
            try:
                os.killpg(os.getpgid(self.process.pid), signal.SIGKILL)
            except ProcessLookupError:
                pass
        self.last_exit = self.process.poll()
        self.process = None
        unregister_process(self.project)
        self.last_status = "stopped"


class RunnerUi:
    def __init__(self, threads: list[ThreadCommand], focus_zed_on_run: bool) -> None:
        self.threads = threads
        self.focus_zed_on_run = focus_zed_on_run
        self.selected = 0
        self.message = "enter/e edit | f focus zed | p add project | s start/rerun | r stop-all+run | x stop | q quit"
        self.commands = load_commands()

    def run(self, stdscr: curses.window) -> None:
        curses.curs_set(0)
        stdscr.nodelay(True)
        stdscr.keypad(True)
        while True:
            for thread in self.threads:
                thread.poll()
            self.draw(stdscr)
            key = stdscr.getch()
            if key == -1:
                time.sleep(0.1)
                continue
            if key in (ord("q"), 27):
                self.stop_all()
                return
            self.handle_key(stdscr, key)

    def draw(self, stdscr: curses.window) -> None:
        stdscr.erase()
        height, width = stdscr.getmaxyx()
        if height <= 0 or width <= 0:
            return
        title = "Zed thread runner"
        self.write_line(stdscr, 0, title, curses.A_REVERSE)
        focused_project = current_zed_project()

        for idx, thread in enumerate(self.threads[: max(0, height - 3)]):
            marker = ">" if idx == self.selected else " "
            token = self.thread_token(thread, focused_project)
            command = thread.command or "<enter command>"
            status = thread.last_status
            line = f"{marker} {token} {thread.name:<24} {status:<13} {command}"
            attr = curses.A_REVERSE if idx == self.selected else curses.A_NORMAL
            self.write_line(stdscr, idx + 1, line, attr)

        if height >= 2:
            self.write_line(stdscr, height - 2, self.message, curses.A_DIM)
            buttons = "[Focus:f] [Start/Rerun:s] [Stop:x] [Stop All:a] [Add:p] [Edit:enter] [Quit:q]"
            self.write_line(stdscr, height - 1, buttons, curses.A_REVERSE)
        stdscr.refresh()

    def write_line(self, stdscr: curses.window, row: int, text: str, attr: int = curses.A_NORMAL) -> None:
        height, width = stdscr.getmaxyx()
        if row < 0 or row >= height or width <= 0:
            return
        limit = width - 1 if row == height - 1 else width
        if limit <= 0:
            return
        try:
            stdscr.addnstr(row, 0, text.ljust(limit), limit, attr)
        except curses.error:
            pass

    def thread_token(self, thread: ThreadCommand, focused_project: Path | None) -> str:
        run = "*"
        if thread.warm_process is not None and thread.warm_process.poll() is None:
            run = "~"
        elif thread.process is not None and thread.process.poll() is None:
            run = "*"
        elif thread.last_status.startswith(("exited 0", "idle", "nix warmed")):
            run = "."
        elif thread.last_status in ("stopped", "missing command") or thread.last_status.startswith(("exited", "warm failed")):
            run = "!"
        focused = "@" if focused_project == thread.project else " "
        return f"{run}{focused}"

    def handle_key(self, stdscr: curses.window, key: int) -> None:
        if key in (curses.KEY_UP, ord("k")):
            self.selected = max(0, self.selected - 1)
        elif key in (curses.KEY_DOWN, ord("j")):
            self.selected = min(len(self.threads) - 1, self.selected + 1)
        elif key in (curses.KEY_ENTER, 10, 13, ord("e")):
            self.edit_command(stdscr)
        elif key == ord("p"):
            self.add_project(stdscr)
        elif key == ord("s"):
            self.start_current(stop_all_first=False)
        elif key == ord("r"):
            self.start_current(stop_all_first=True)
        elif key == ord("x"):
            self.current.stop()
        elif key == ord("a"):
            self.stop_all()
            self.message = "stopped all running commands"
        elif key == ord("w"):
            self.current.warm()
        elif key == ord("W"):
            for thread in self.threads:
                thread.warm()
            self.message = "warming all nix shells"
        elif key == ord("l"):
            self.message = f"log: {self.current.log_path}"
        elif key in (ord("f"), ord("z")):
            self.focus_current()

    @property
    def current(self) -> ThreadCommand:
        return self.threads[self.selected]

    def edit_command(self, stdscr: curses.window) -> None:
        command = self.read_prompt(stdscr, f"command for {self.current.name}: ", self.current.command)
        if command:
            self.current.command = command
            self.persist_current()
            self.message = f"set {self.current.name}: {command}"

    def add_project(self, stdscr: curses.window) -> None:
        raw_path = self.read_prompt(stdscr, "project path: ", "")
        if not raw_path:
            return
        project = Path(raw_path).expanduser().resolve()
        if not project.exists() or not project.is_dir():
            self.message = f"not a directory: {project}"
            return
        projects = add_projects([project])
        if all(thread.project != project for thread in self.threads):
            command = load_commands().get(str(project), "")
            self.threads.append(ThreadCommand(project=project, command=command))
            self.selected = len(self.threads) - 1
        self.message = f"registered {project.name} ({len(projects)} total)"

    def read_prompt(self, stdscr: curses.window, prompt: str, initial: str) -> str:
        stdscr.nodelay(False)
        curses.echo()
        curses.curs_set(1)
        height, width = stdscr.getmaxyx()
        input_width = max(1, width - 1)
        if len(prompt) >= input_width:
            prompt = "> "
        self.write_line(stdscr, height - 1, "")
        try:
            stdscr.addnstr(height - 1, 0, prompt, input_width)
        except curses.error:
            pass
        stdscr.refresh()
        if initial:
            try:
                stdscr.addnstr(height - 1, len(prompt), initial, max(0, input_width - len(prompt)))
            except curses.error:
                pass
        try:
            raw = stdscr.getstr(height - 1, len(prompt), max(1, input_width - len(prompt)))
        finally:
            curses.noecho()
            curses.curs_set(0)
            stdscr.nodelay(True)
        return raw.decode(errors="replace").strip()

    def persist_current(self) -> None:
        self.commands[self.current.key] = self.current.command
        save_commands(self.commands)

    def focus_current(self) -> None:
        message, popped = focus_project_in_zed(self.current.project)
        self.remove_popped_threads(popped)
        self.message = message

    def remove_popped_threads(self, popped: list[Path]) -> None:
        if not popped:
            return
        popped_set = set(popped)
        for thread in self.threads:
            if thread.project in popped_set:
                thread.stop()
        self.threads = [thread for thread in self.threads if thread.project not in popped_set]
        self.selected = min(self.selected, max(0, len(self.threads) - 1))

    def start_current(self, stop_all_first: bool) -> None:
        thread = self.current
        if stop_all_first:
            self.stop_all()
        if self.focus_zed_on_run:
            message, popped = focus_project_in_zed(thread.project)
            self.remove_popped_threads(popped)
            self.message = message
        thread.start()
        self.commands[thread.key] = thread.command
        save_commands(self.commands)
        prefix = "stopped all, " if stop_all_first else ""
        self.message = f"{prefix}running {thread.name}"

    def stop_all(self) -> None:
        for thread in self.threads:
            thread.stop()
        stop_all_registered_processes()


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run per-worktree commands through nix shells.")
    parser.add_argument("projects", nargs="*", help="Project/worktree directories. Defaults to git worktrees or cwd.")
    parser.add_argument("--command", "-c", help="Initial command for projects without a saved command.")
    parser.add_argument("--warm", action="store_true", help="Warm detected nix shells on startup.")
    parser.add_argument(
        "--focus-zed-on-run",
        action="store_true",
        help="Run 'zed --existing <project>' before starting a selected thread command.",
    )
    parser.add_argument(
        "--run-project",
        metavar="PROJECT",
        help="Run the saved/default command for PROJECT without opening the TUI.",
    )
    parser.add_argument(
        "--stop-all",
        action="store_true",
        help="Stop all tracked thread commands and exit unless --run-project is also provided.",
    )
    parser.add_argument(
        "--stop-all-first",
        action="store_true",
        help="Stop all tracked thread commands before --run-project.",
    )
    parser.add_argument(
        "--add-project",
        action="append",
        default=[],
        metavar="PROJECT",
        help="Add PROJECT to the persistent runner thread list. Can be passed more than once.",
    )
    parser.add_argument(
        "--remove-project",
        action="append",
        default=[],
        metavar="PROJECT",
        help="Remove PROJECT from the persistent runner thread list. Can be passed more than once.",
    )
    parser.add_argument(
        "--list-projects",
        action="store_true",
        help="List registered runner projects and exit.",
    )
    parser.add_argument(
        "--register-args",
        action="store_true",
        help="Register positional project arguments before opening the TUI.",
    )
    parser.add_argument(
        "--no-zed-sync",
        action="store_true",
        help="Do not merge projects found in Zed's local thread/workspace databases.",
    )
    parser.add_argument(
        "--sync-zed-projects",
        action="store_true",
        help="Persist projects found in Zed's local thread/workspace databases and exit.",
    )
    parser.add_argument(
        "--list-zed-projects",
        action="store_true",
        help="List projects found in Zed's local thread/workspace databases and exit.",
    )
    return parser.parse_args(argv)


def build_threads(projects: list[Path], default_command: str | None) -> list[ThreadCommand]:
    commands = load_commands()
    threads: list[ThreadCommand] = []
    for project in projects:
        saved_command = commands.get(str(project), "")
        command = saved_command or default_command or ""
        threads.append(ThreadCommand(project=project, command=command))
    return threads


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    cwd = Path.cwd().resolve()

    if args.add_project:
        projects = add_projects(Path(project) for project in args.add_project)
        for project in projects:
            print(project)
        return 0

    if args.remove_project:
        projects = remove_projects(Path(project) for project in args.remove_project)
        for project in projects:
            print(project)
        return 0

    if args.list_projects:
        for project in load_projects():
            print(project)
        return 0

    if args.list_zed_projects:
        for project in zed_thread_projects():
            print(project)
        return 0

    if args.sync_zed_projects:
        projects = add_projects(zed_thread_projects())
        for project in projects:
            print(project)
        return 0

    if args.stop_all and not args.run_project:
        stopped = stop_all_registered_processes()
        print(f"stopped {stopped} tracked command(s)")
        return 0

    if args.run_project:
        project = Path(args.run_project).expanduser().resolve()
        if args.stop_all_first or args.stop_all:
            stop_all_registered_processes()
        thread = build_threads([project], args.command)[0]
        if args.focus_zed_on_run:
            message, _ = focus_project_in_zed(project)
            print(message)
        thread.start()
        if thread.process is None:
            print(thread.last_status, file=sys.stderr)
            return 1
        print(f"running {project}: pid {thread.process.pid}")
        return 0

    projects = unique_existing(Path(path) for path in args.projects)
    if args.register_args and projects:
        projects = add_projects(projects)
    if not projects:
        projects = default_projects(cwd, sync_zed=not args.no_zed_sync)
    threads = build_threads(projects, args.command)
    if args.warm:
        for thread in threads:
            thread.warm()

    try:
        curses.wrapper(RunnerUi(threads, focus_zed_on_run=args.focus_zed_on_run).run)
    except KeyboardInterrupt:
        for thread in threads:
            thread.stop()
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
