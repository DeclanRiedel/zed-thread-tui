[
  {
    "label": "thread runner: current worktree",
    "command": "nix",
    "args": [
      "run",
      "/home/declan/personal/thread-run-script-runner-zed",
      "--",
      "--focus-zed-on-run",
      "$ZED_WORKTREE_ROOT"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": true,
    "reveal": "always",
    "hide": "never"
  },
  {
    "label": "thread runner: all git worktrees",
    "command": "nix",
    "args": [
      "run",
      "/home/declan/personal/thread-run-script-runner-zed",
      "--",
      "--focus-zed-on-run"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": true,
    "reveal": "always",
    "hide": "never"
  },
  {
    "label": "thread runner: stop all then run current worktree",
    "command": "nix",
    "args": [
      "run",
      "/home/declan/personal/thread-run-script-runner-zed",
      "--",
      "--stop-all-first",
      "--focus-zed-on-run",
      "--run-project",
      "$ZED_WORKTREE_ROOT"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": true,
    "reveal": "no_focus",
    "hide": "on_success"
  },
  {
    "label": "thread runner: stop all",
    "command": "nix",
    "args": [
      "run",
      "/home/declan/personal/thread-run-script-runner-zed",
      "--",
      "--stop-all"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": true,
    "reveal": "no_focus",
    "hide": "on_success"
  },
  {
    "label": "thread runner: register current worktree",
    "command": "nix",
    "args": [
      "run",
      "/home/declan/personal/thread-run-script-runner-zed",
      "--",
      "--add-project",
      "$ZED_WORKTREE_ROOT"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": true,
    "reveal": "no_focus",
    "hide": "on_success"
  }
]
